rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════════════
    // CORE HELPER FUNCTIONS
    // ═══════════════════════════════════════════════════════════════════════

    // True when a Firebase Auth session exists.
    function isAuth() {
      return request.auth != null;
    }

    // ── App Check ──────────────────────────────────────────────────────────
    // App Check enforcement is handled EXCLUSIVELY by the Firebase Console
    // toggle (Firebase Console → App Check → Firestore → Enforced / Monitor).
    //
    // When set to "Enforced": Firebase rejects every request without a valid
    //   App Check token BEFORE the rules are evaluated.  No rule change needed.
    // When set to "Monitor": requests are logged but allowed through, so the
    //   rules run normally for all authenticated users.
    //
    // We do NOT check request.app inside rules because:
    //   • It breaks Monitor mode (request.app is null even for legitimate users).
    //   • It breaks localhost dev (reCAPTCHA can't run on 127.0.0.1).
    //   • It is redundant when Enforce mode is active (Firebase already blocked
    //     the unauthenticated request before rules execute).
    //
    // isAppCheckValid() is kept ONLY for public-catalogue rules where we want
    // an extra check that the request comes from the app binary (not a browser
    // curl) even before the user has signed in.
    function isAppCheckValid() {
      return request.app != null;
    }

    // Authenticated user — the primary gate for all client operations.
    // App Check enforcement is the Firebase Console's responsibility, not ours.
    function isVerifiedAuth() {
      return isAuth();
    }

    // The current user owns this document (matches the UID path parameter).
    function isOwner(uid) {
      return isVerifiedAuth() && request.auth.uid == uid;
    }

    // Admin check — Firestore flag only; email removed (see security audit).
    // isAdmin can only be set via Admin SDK / Firebase Console.
    function isAdmin() {
      return isVerifiedAuth()
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // ── Support Agent role (v11.9.x) ────────────────────────────────────
    // A support_agent is staff member who can view tickets, take ownership,
    // chat with customers, and run a controlled set of actions (verify ID,
    // password reset, flag account, refund within cap). They CANNOT access
    // the Vault: financial settings, platform earnings, system broadcasts,
    // grantAdminCredit, or change other users' roles.
    //
    // Role assignment goes through the setUserRole CF (admin-only).
    function isSupportAgent() {
      return isVerifiedAuth()
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'support_agent';
    }

    // Convenience: any staff member (admin OR support_agent).
    // Use this for collections that BOTH roles need to read.
    function isStaff() {
      return isAdmin() || isSupportAgent();
    }

    // CMS admin check — now uses the same Firestore isAdmin flag.
    // Previously was email-based; unified to prevent hardcoded credentials.
    // Kept as a separate function for readability in collection rules.
    function isCmsAdmin() {
      return isAdmin();
    }

    // ── Field-level write guards (reusable) ───────────────────────────────

    // Returns true when the update touches ONLY the listed keys.
    function onlyFields(keys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys);
    }

    // Returns true when the update does NOT touch any of the listed keys.
    function doesNotTouch(keys) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(keys);
    }


    // ═══════════════════════════════════════════════════════════════════════
    // USERS
    // ═══════════════════════════════════════════════════════════════════════
    //
    // Privacy model:
    //   • Any authenticated + app-verified user may READ a profile.
    //     All public fields (name, bio, skills, rating, profileImage) live
    //     at the top level and are intentionally visible for search results.
    //   • Sensitive fields (balance, bankDetails, taxId, phone) are protected
    //     at the WRITE layer — only the owner can write them, and the read
    //     exposure is an accepted trade-off of a flat document model.
    //     For a future hardening step, move sensitive fields to a private
    //     subcollection: users/{uid}/private/data (owner-read only).
    //   • Server-only fields (xp, isAdmin, isVerified, balance increments)
    //     are blocked at the write layer below.
    //
    match /users/{uid} {
      // Owner can always read their own doc (even during signup before it exists).
      // Any other authenticated user can read public profile data.
      allow read: if request.auth != null;

      // Owner can create their own profile. System account also allowed.
      // Uses direct auth check — no get() calls that could fail on missing docs.
      // Admins may also create user docs with arbitrary UIDs (used by the
      // demo experts admin tab to seed and create demo provider profiles).
      allow create: if (request.auth != null && request.auth.uid == uid)
                    || isAdmin();

      allow update: if
        // ── Owner general update ───────────────────────────────────────────
        // Owner may update any field EXCEPT server-only fields.
        (isOwner(uid) && doesNotTouch([
          'xp', 'current_xp', 'level', 'isPromoted',
          'isVerifiedProvider', 'isVerified', 'isAdmin',
          'balance',
        ]))
        // ── Owner balance decrement (client-side escrow payment) ──────────
        // Owner may ONLY decrease their own balance. Increments are
        // handled exclusively by Cloud Functions via Admin SDK.
        || (isOwner(uid)
            && onlyFields(['balance'])
            && resource.data.balance is number
            && request.resource.data.balance is number
            && request.resource.data.balance <= resource.data.balance)
        // ── Admin full access ──────────────────────────────────────────────
        || isAdmin()
        // ── Review aggregation ────────────────────────────────────────────
        // Any verified user may update only the rating + reviewsCount fields
        // (written after a client review submission). Business logic in the
        // client prevents abuse; a Cloud Function audit runs nightly.
        || (isVerifiedAuth() && onlyFields(['rating', 'reviewsCount']))
        // Any verified user may update only the customerRating +
        // customerReviewsCount fields (written after an expert review
        // of a customer is published).
        || (isVerifiedAuth() && onlyFields(['customerRating', 'customerReviewsCount']))
        // ── Volunteer / Community Hub badge update ─────────────────────
        // Client confirms volunteer task completion → updates provider's
        // badge timestamp, count, heart, community badges, and community XP.
        // Standard XP increment is handled by CF (updateUserXP).
        || (isVerifiedAuth() && onlyFields([
             'lastVolunteerTaskAt', 'volunteerTaskCount', 'hasActiveVolunteerBadge',
             'volunteerHeart', 'communityBadges', 'communityXP'
           ]))
        // ── Engagement: streak + profile boost ───────────────────────────
        // Provider writes streak data on own doc; engagement service writes
        // profileBoostUntil when a boost card is awarded.
        || (isOwner(uid) && onlyFields(['streak', 'lastStreakDate', 'streakBestEver', 'lastDailyDropDate', 'profileBoostUntil']))
        // ── Escrow credit (pendingBalance) ───────────────────────────────
        // v9.7.0 SECURITY: pendingBalance writes are now restricted to
        // INCREMENT-ONLY by verified users. This prevents:
        //   • Setting pendingBalance to an arbitrary value (griefing)
        //   • Setting pendingBalance to a negative number
        //   • Decreasing another user's pendingBalance
        // The new value MUST be strictly greater than the current value.
        // Cloud Functions (Admin SDK) bypass rules for resets/corrections.
        || (isVerifiedAuth()
            && onlyFields(['pendingBalance'])
            && request.resource.data.pendingBalance > resource.data.pendingBalance);

      // Deletion is only performed by the Account Deletion Cloud Function
      // (Admin SDK) or the self-service delete flow (account_deletion_service.dart
      // calls currentUser.delete(), and the CF cleans up the doc).
      allow delete: if isOwner(uid) || isAdmin();
    }


    // ═══════════════════════════════════════════════════════════════════════
    // PRIVATE USER SUBCOLLECTIONS
    // Strictly owner-only. No other authenticated user — not even an admin
    // using the client SDK — may access these paths.
    // (Admin SDK via Cloud Functions bypasses all rules and is unaffected.)
    // ═══════════════════════════════════════════════════════════════════════

    // ── Academy User Progress ─────────────────────────────────────────────
    match /user_progress/{uid} {
      allow read:  if isOwner(uid) || isAdmin();
      allow write: if false; // top-level doc never written directly

      match /courses/{courseId} {
        allow read:           if isOwner(uid) || isAdmin();
        allow create, update: if isOwner(uid);
        allow delete:         if false;
      }
    }

    // ── Private financial data ──────────────────────────────────────────
    // Sensitive fields (balance, bankDetails, taxId, phone) that should
    // NOT be readable by other users. Owner + Admin only.
    // Cloud Functions (Admin SDK) bypass rules and can always read/write.
    match /users/{uid}/private/{docId} {
      allow read:           if isOwner(uid) || isAdmin();
      allow create, update: if isOwner(uid) || isAdmin();
      allow delete:         if isAdmin();
    }

    // ── Dog Profiles (Pet Stay Tracker v13.0.0) ─────────────────────────
    // Owner-only master profile. Provider never reads here — a snapshot is
    // copied onto the job doc at booking time (see jobs/{id}/petStay/data).
    match /users/{uid}/dogProfiles/{dogId} {
      allow read, write: if isOwner(uid);
    }

    // ── Legacy per-user notification subcollection ────────────────────────
    match /notifications/{uid}/userNotifications/{notifId} {
      allow read, write: if isOwner(uid);
    }


    // ═══════════════════════════════════════════════════════════════════════
    // NOTIFICATIONS (flat collection — written by Cloud Functions)
    // ═══════════════════════════════════════════════════════════════════════
    match /notifications/{notifId} {
      // Owner reads their own notifications.
      allow read: if isVerifiedAuth() && resource.data.userId == request.auth.uid;

      // Owner may only flip isRead — no other field changes from the client.
      allow update: if isVerifiedAuth()
                    && resource.data.userId == request.auth.uid
                    && onlyFields(['isRead']);

      // Normal creation path = Admin SDK in Cloud Functions.
      // Client code also creates notifications for volunteer/help_request flows.
      // Size limit: prevent abuse at scale (max 10 fields, body < 1000 chars).
      allow create: if isAdmin()
                    || (isVerifiedAuth()
                        && request.resource.data.keys().size() <= 10
                        && request.resource.data.get('body', '').size() <= 1000);

      // Owner may dismiss (delete) their own notifications.
      allow delete: if isVerifiedAuth() && resource.data.userId == request.auth.uid;
    }


    // ═══════════════════════════════════════════════════════════════════════
    // JOBS (bookings)
    // Only the customer and expert involved in a booking may access it.
    // ═══════════════════════════════════════════════════════════════════════
    match /jobs/{jobId} {
      // Customer creates the job and must be the customerId author.
      // Self-booking is forbidden — a provider cannot book themselves
      // (anti-fraud: prevents fake reviews and circular money flows).
      allow create: if isVerifiedAuth()
                    && request.resource.data.customerId == request.auth.uid
                    && request.resource.data.customerId != request.resource.data.expertId;

      // Only the two parties (or admin) may read.
      allow read: if isAdmin()
                  || (isVerifiedAuth()
                      && (resource.data.customerId == request.auth.uid
                          || resource.data.expertId  == request.auth.uid));

      // Both parties may update (status transitions, completion).
      allow update: if isAdmin()
                    || (isVerifiedAuth()
                        && (resource.data.expertId   == request.auth.uid
                            || resource.data.customerId == request.auth.uid));

      allow delete: if false; // historical record — never deleted by client

      // ── PetStay snapshot (Pet Stay Tracker v13.0.0) ──────────────────
      // Lives at jobs/{jobId}/petStay/{docId}. Created in the SAME
      // transaction as the parent job doc, so the create rule can't
      // get(/jobs/{jobId}) — it's not committed yet. We rely on the
      // customerId field that the customer writes onto the snapshot.
      // For read/update later, we get() the (now committed) parent job.
      match /petStay/{docId} {
        allow create: if isAdmin()
                      || (isVerifiedAuth()
                          && request.resource.data.customerId == request.auth.uid);
        allow read: if isAdmin()
                    || (isVerifiedAuth()
                        && (resource.data.customerId == request.auth.uid
                            || resource.data.expertId  == request.auth.uid));
        // Fine-grained write permissions (QA Phase 2 fix):
        //   • Customer → rating / review / ratedAt / status only
        //     (submitRating flips status to 'completed')
        //   • Provider → counters + status only (NO rating writes)
        //   • Neither side may touch dogSnapshot, customerId, expertId,
        //     isPension, isDogWalker, startDate, endDate, totalNights
        allow update: if isAdmin()
                      || (isVerifiedAuth() && (
                        (resource.data.customerId == request.auth.uid
                         && request.resource.data.diff(resource.data)
                            .affectedKeys()
                            .hasOnly(['rating', 'reviewText', 'ratedAt',
                                      'status', 'dogSnapshot']))
                        || (resource.data.expertId == request.auth.uid
                            && request.resource.data.diff(resource.data)
                               .affectedKeys()
                               .hasOnly(['totalWalks', 'totalDistanceKm',
                                         'totalPhotos', 'totalVideos',
                                         'totalReports', 'status']))
                      ));
        allow delete: if false;

        // ── Schedule items (Step 5) ────────────────────────────────────
        // Created by the customer during the booking transaction.
        // Updated by the expert to mark items done. Read by both parties.
        // Bootstrap-safe: `customerId`/`expertId` are duplicated on each
        // schedule item so the rules don't need to get(/jobs/{jobId}).
        match /schedule/{itemId} {
          allow create: if isVerifiedAuth()
                        && request.resource.data.customerId == request.auth.uid;
          allow read: if isAdmin()
                      || (isVerifiedAuth()
                          && (resource.data.customerId == request.auth.uid
                              || resource.data.expertId  == request.auth.uid));
          allow update: if isAdmin()
                        || (isVerifiedAuth()
                            && resource.data.expertId == request.auth.uid);
          allow delete: if false;
        }

        // ── Feed updates (Step 6+) ─────────────────────────────────────
        // Written by the provider as stay events happen (pee/poop marker,
        // walk_completed, photos/videos/notes, daily_report). Read by both
        // participants. Step 9: the customer can touch ONLY `reactions` and
        // `replies` — all other fields stay provider-owned.
        match /updates/{updateId} {
          allow create: if isVerifiedAuth()
                        && request.resource.data.expertId == request.auth.uid;
          allow read: if isAdmin()
                      || (isVerifiedAuth()
                          && (resource.data.customerId == request.auth.uid
                              || resource.data.expertId  == request.auth.uid));
          allow update: if isAdmin()
                        || (isVerifiedAuth()
                            && (
                              // Provider: full write access on their own update.
                              resource.data.expertId == request.auth.uid
                              // Customer: reactions/replies only.
                              || (resource.data.customerId == request.auth.uid
                                  && request.resource.data.diff(resource.data)
                                     .affectedKeys()
                                     .hasOnly(['reactions', 'replies']))
                            ));
          allow delete: if false;
        }
      }
    }


    // ═══════════════════════════════════════════════════════════════════════
    // TRANSACTIONS (wallet history)
    // Only the sender, receiver, or admin may access a transaction.
    // ═══════════════════════════════════════════════════════════════════════
    match /transactions/{txId} {
      // Sender creates their own transaction record.
      allow create: if isVerifiedAuth()
                    && (request.resource.data.userId   == request.auth.uid
                        || request.resource.data.senderId == request.auth.uid);

      // Only the two parties (or admin) may read.
      allow read: if isAdmin()
                  || (isVerifiedAuth()
                      && (resource.data.userId     == request.auth.uid
                          || resource.data.senderId  == request.auth.uid
                          || resource.data.receiverId == request.auth.uid));

      allow update, delete: if false; // immutable financial records
    }


    // ═══════════════════════════════════════════════════════════════════════
    // CHATS & MESSAGES
    // Strictly participant-only: only the two users listed in chat.users[]
    // may read or write. Guessing a chatId grants nothing.
    // ═══════════════════════════════════════════════════════════════════════
    match /chats/{chatId} {
      allow create: if isVerifiedAuth()
                    && request.auth.uid in request.resource.data.users;

      allow read, update:
            if isVerifiedAuth()
            && request.auth.uid in resource.data.users;

      // Allow participant to delete the chat room document.
      allow delete: if isVerifiedAuth()
                    && request.auth.uid in resource.data.users;

      match /messages/{msgId} {
        // Inherit parent-room access: caller must be in the parent chat's users[].
        allow read, write:
          if isVerifiedAuth()
          && request.auth.uid in
             get(/databases/$(database)/documents/chats/$(chatId)).data.users;
      }

      match /unread_shards/{shardId} {
        // Read-only for participants — shards are written by Cloud Functions only.
        allow read: if isVerifiedAuth()
                    && request.auth.uid in
                       get(/databases/$(database)/documents/chats/$(chatId)).data.users;
        allow write: if false;
      }

      // v9.5.5: Typing indicators in separate subcollection to prevent
      // AsyncQueue deadlocks (write + listener on same parent doc).
      match /typing/{uid} {
        allow read: if isVerifiedAuth()
                    && request.auth.uid in
                       get(/databases/$(database)/documents/chats/$(chatId)).data.users;
        allow write: if isVerifiedAuth()
                     && request.auth.uid == uid;
      }
    }


    // ═══════════════════════════════════════════════════════════════════════
    // QUOTES (price quotes sent via chat)
    // Only the provider and client involved may read or update.
    // ═══════════════════════════════════════════════════════════════════════
    match /quotes/{quoteId} {
      allow create: if isVerifiedAuth()
                    && request.resource.data.providerId == request.auth.uid;

      allow read: if isAdmin()
                  || (isVerifiedAuth()
                      && (resource.data.providerId == request.auth.uid
                          || resource.data.clientId  == request.auth.uid));

      allow update: if isAdmin()
                    || (isVerifiedAuth()
                        && (resource.data.providerId == request.auth.uid
                            || resource.data.clientId  == request.auth.uid));

      allow delete: if isAdmin() || isCmsAdmin();
    }


    // ═══════════════════════════════════════════════════════════════════════
    // WITHDRAWALS
    // ═══════════════════════════════════════════════════════════════════════
    match /withdrawals/{id} {
      allow create: if isVerifiedAuth()
                    && request.resource.data.userId == request.auth.uid;

      // Explicit parentheses to avoid && vs || precedence ambiguity.
      allow read: if isAdmin()
                  || (isVerifiedAuth() && resource.data.userId == request.auth.uid);

      allow update: if isAdmin() || isCmsAdmin();
      allow delete: if false;
    }


    // ═══════════════════════════════════════════════════════════════════════
    // BOOKING SLOTS (double-booking lock documents)
    // ═══════════════════════════════════════════════════════════════════════
    match /bookingSlots/{slotId} {
      allow read:   if isVerifiedAuth();
      allow create: if isVerifiedAuth();
      allow delete: if isAdmin() || isCmsAdmin();
      allow update: if false;
    }


    // ═══════════════════════════════════════════════════════════════════════
    // PLATFORM EARNINGS (commission records)
    // ═══════════════════════════════════════════════════════════════════════
    match /platform_earnings/{id} {
      allow create: if isVerifiedAuth();
      allow read:   if isAdmin() || isCmsAdmin();
      allow update, delete: if false;
    }


    // ═══════════════════════════════════════════════════════════════════════
    // PUBLIC CATALOGUES
    // Read by anyone from the verified app (isAppCheckValid()).
    // Unauthenticated visitors may browse before signing in.
    // All writes are admin-only.
    // ═══════════════════════════════════════════════════════════════════════

    match /categories/{catId} {
      // Authenticated users always get through; unauthenticated visitors on
      // production need a valid App Check token (reCAPTCHA / Play Integrity).
      allow read:  if isAuth() || isAppCheckValid();
      allow write: if isAdmin() || isCmsAdmin();
    }

    match /application_content/{locale} {
      // CMS content overrides: readable by authenticated users, writable only by CMS admin.
      allow read:  if isAuth() || isAppCheckValid();
      allow write: if isAdmin() || isCmsAdmin();

      // Nested documents (if any) inherit the same rules.
      match /{document=**} {
        allow read:  if isAuth() || isAppCheckValid();
        allow write: if isAdmin() || isCmsAdmin();
      }
    }

    match /courses/{courseId} {
      allow read:  if isAuth() || isAppCheckValid();
      allow write: if isAdmin() || isCmsAdmin();
    }

    match /system_settings/{docId} {
      allow read:  if isAuth() || isAppCheckValid();
      allow write: if isAdmin() || isCmsAdmin();
    }

    match /app_hints/{screenKey} {
      allow read:  if isAuth() || isAppCheckValid();
      allow write: if isAdmin() || isCmsAdmin();
    }

    match /banners/{id} {
      allow read:   if isAuth() || isAppCheckValid();
      allow create, delete: if isAdmin() || isCmsAdmin();
      allow update: if isAdmin()
                    || (isVerifiedAuth() && onlyFields(['clicks']));
    }

    match /completed_works/{docId} {
      allow read:  if isAuth() || isAppCheckValid(); // public inspiration feed
      allow write: if false;                         // Admin SDK (Cloud Function) only
    }


    // ═══════════════════════════════════════════════════════════════════════
    // REVIEWS  (double-blind: published when both submit OR after 7 days)
    //
    // isPublished starts false; flipped to true by client code when:
    //   • both job.clientReviewDone AND job.providerReviewDone are true, OR
    //   • 7 days have passed since the review was created (lazy publish).
    //
    // Neither condition leaks the other party's content — only the flag
    // is toggled client-side; content fields are immutable after creation.
    // ═══════════════════════════════════════════════════════════════════════

    // Checks that the current user is a job participant AND both sides
    // have now submitted their review — used to allow immediate publish.
    function canPublishReview(jobId) {
      let job = get(/databases/$(database)/documents/jobs/$(jobId)).data;
      return (job.expertId    == request.auth.uid
              || job.customerId == request.auth.uid)
          && job.clientReviewDone   == true
          && job.providerReviewDone == true;
    }

    match /reviews/{reviewId} {
      allow read: if isAuth() || isAppCheckValid();

      // A verified user may create a review when:
      //   1. They are the reviewer (reviewerId == their uid), AND
      //   2. They are actually a participant in the referenced job
      //      (prevents writing reviews for jobs they were not part of).
      allow create: if isAdmin()
                    || (isVerifiedAuth()
                        && request.resource.data.reviewerId == request.auth.uid
                        && (get(/databases/$(database)/documents/jobs/$(request.resource.data.jobId)).data.customerId == request.auth.uid
                            || get(/databases/$(database)/documents/jobs/$(request.resource.data.jobId)).data.expertId  == request.auth.uid));

      allow update: if isAdmin()
                    // The reviewee (expert) may add/edit their reply to a
                    // client review written about them.
                    || (isVerifiedAuth()
                        && resource.data.revieweeId   == request.auth.uid
                        && resource.data.isClientReview == true
                        && onlyFields(['providerResponse']))
                    // Immediate publish: a job participant may flip isPublished
                    // once BOTH sides have submitted their review.
                    || (isVerifiedAuth()
                        && onlyFields(['isPublished'])
                        && request.resource.data.isPublished == true
                        && canPublishReview(resource.data.jobId))
                    // Lazy publish: any authenticated user may flip isPublished
                    // after the 7-day double-blind window has expired.
                    || (isVerifiedAuth()
                        && onlyFields(['isPublished'])
                        && request.resource.data.isPublished == true
                        && request.time > resource.data.createdAt + duration.value(7, 'd'));

      allow delete: if isAdmin() || isCmsAdmin();
    }


    // ═══════════════════════════════════════════════════════════════════════
    // SKILLS STORIES
    // ═══════════════════════════════════════════════════════════════════════
    match /stories/{uid} {
      allow read:   if isVerifiedAuth();
      allow create: if isOwner(uid);
      // Owner can update any field. Other users can only toggle
      // engagement fields (view/like) — prevents story content hijacking.
      allow update: if isOwner(uid)
                    || isAdmin()
                    || (isVerifiedAuth()
                        && onlyFields(['viewCount', 'likeCount', 'likedBy']));
      allow delete: if isOwner(uid) || isAdmin();
    }


    // ═══════════════════════════════════════════════════════════════════════
    // JOB REQUESTS (quick-order board)
    // ═══════════════════════════════════════════════════════════════════════
    match /job_requests/{reqId} {
      allow read:   if isVerifiedAuth();
      allow create: if isVerifiedAuth()
                    && request.resource.data.clientId == request.auth.uid;
      allow update: if isVerifiedAuth()
                    && (onlyFields(['interestedProviders', 'interestedProviderNames',
                                    'interestedCount', 'status'])
                        || resource.data.clientId == request.auth.uid);
      allow delete: if isVerifiedAuth() && resource.data.clientId == request.auth.uid;
    }


    // ═══════════════════════════════════════════════════════════════════════
    // VOLUNTEER REQUESTS
    // ═══════════════════════════════════════════════════════════════════════
    match /volunteer_requests/{reqId} {
      allow create: if isVerifiedAuth()
                    && request.resource.data.clientId == request.auth.uid;
      allow read:   if isAdmin()
                    || (isVerifiedAuth() && resource.data.clientId == request.auth.uid);
      allow update: if isAdmin() || isCmsAdmin();
      allow delete: if false;
    }


    // ═══════════════════════════════════════════════════════════════════════
    // CATEGORY REQUESTS ("Other" custom category pending admin approval)
    // ═══════════════════════════════════════════════════════════════════════
    match /category_requests/{reqId} {
      allow create: if isVerifiedAuth()
                    && request.resource.data.userId == request.auth.uid;
      allow read:   if isAdmin()
                    || (isVerifiedAuth() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || isCmsAdmin();
      allow delete: if isAdmin() || isCmsAdmin();
    }


    // ═══════════════════════════════════════════════════════════════════════
    // SUPPORT TICKETS (user↔admin support chat)
    //
    // Users create tickets and read/update their own.
    // Admins can read and update all tickets.
    // ═══════════════════════════════════════════════════════════════════════
    match /support_tickets/{ticketId} {
      allow create: if isVerifiedAuth()
                    && request.resource.data.userId == request.auth.uid;

      // Read: any staff member (admin or support_agent) + the ticket owner.
      allow read: if isStaff()
                  || (isVerifiedAuth() && resource.data.userId == request.auth.uid);

      // Update: admin (all tickets), support_agent (any ticket — they need
      // to be able to claim/assign before they own it), and the ticket owner.
      allow update: if isStaff()
                    || (isVerifiedAuth() && resource.data.userId == request.auth.uid);

      allow delete: if isAdmin() || isCmsAdmin();

      match /messages/{msgId} {
        // Read: staff sees everything (including internal notes).
        // Customer sees only NON-internal messages — enforced via the
        // resource.data.isInternal field. Internal notes have isInternal=true
        // and are filtered out from customer queries.
        allow read: if isStaff()
                    || (isVerifiedAuth()
                        && resource.data.isInternal != true
                        && get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.userId == request.auth.uid);

        // Create: staff can write any message (including internal notes).
        // Customer can only write non-internal messages tagged with their uid.
        allow create: if isStaff()
                      || (isVerifiedAuth()
                          && request.resource.data.isInternal != true
                          && get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.userId == request.auth.uid);
      }
    }

    // ═══════════════════════════════════════════════════════════════════════
    // SUPPORT AUDIT LOG (v11.9.x — agent action trail)
    //
    // Every sensitive action a support_agent or admin performs is logged
    // here by the supportAgentAction Cloud Function. Admins can read the
    // full log; agents can read their own entries to review their work.
    // Nobody can update or delete — append-only.
    // ═══════════════════════════════════════════════════════════════════════
    match /support_audit_log/{logId} {
      // Reads: admin sees all, agent sees their own
      allow read: if isAdmin()
                  || (isSupportAgent()
                      && resource.data.agentUid == request.auth.uid);

      // Writes: only via Cloud Functions (Admin SDK bypasses these rules).
      // Direct client writes are blocked to keep the log tamper-proof.
      allow create, update, delete: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════
    // CANNED RESPONSES (v11.9.x — agent reply templates)
    //
    // Admin creates and manages templates. Agents read them when composing
    // replies. Templates may contain {customerName} and {ticketId} placeholders.
    // ═══════════════════════════════════════════════════════════════════════
    match /canned_responses/{templateId} {
      allow read: if isStaff();
      allow create, update, delete: if isAdmin();
    }


    // ═══════════════════════════════════════════════════════════════════════
    // APP SETTINGS (admin-managed global configuration)
    // Readable by all authenticated users (e.g., sound mappings on startup).
    // Writable only by admins.
    // ═══════════════════════════════════════════════════════════════════════
    match /app_settings/{docId} {
      allow read:  if isVerifiedAuth();
      allow write: if isAdmin() || isCmsAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // AI TEACHERS (Alex profile — admin-managed, public read)
    // ═══════════════════════════════════════════════════════════════════════
    match /ai_teachers/{teacherId} {
      allow read:  if isVerifiedAuth();
      allow write: if isAdmin();
    }


    // ═══════════════════════════════════════════════════════════════════════
    // USER REWARDS (Daily Drop, streak milestones, engagement rewards)
    // ═══════════════════════════════════════════════════════════════════════
    match /user_rewards/{rewardId} {
      allow create: if isVerifiedAuth()
                    && request.resource.data.userId == request.auth.uid;
      allow read:   if isVerifiedAuth()
                    && resource.data.userId == request.auth.uid;
      allow update: if isVerifiedAuth()
                    && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() || isCmsAdmin();
    }


    // ═══════════════════════════════════════════════════════════════════════
    // JOB BROADCASTS (urgent first-come-first-served claims)
    //
    // Created by the client (via JobBroadcastService). Any authenticated
    // provider may read (to see available broadcasts) and update (to claim).
    // Claim atomicity is enforced by Firestore transaction in the service.
    // ═══════════════════════════════════════════════════════════════════════
    match /job_broadcasts/{broadcastId} {
      allow create: if isVerifiedAuth()
                    && request.resource.data.clientId == request.auth.uid;

      allow read: if isVerifiedAuth();

      // Only the broadcast owner or an admin can update.
      // Claim atomicity is enforced by Firestore transaction in the service —
      // providers update status to 'claimed' + set claimedBy fields.
      allow update: if isVerifiedAuth()
                    && (resource.data.clientId == request.auth.uid
                        || onlyFields(['status', 'claimedBy', 'claimedByName', 'claimedAt']));

      allow delete: if isAdmin() || isCmsAdmin();
    }


    // ═══════════════════════════════════════════════════════════════════════
    // PROVIDER LISTINGS — v10.3.1 Dual-Identity System
    // Each doc = one professional identity for a provider. Max 2 per user.
    //
    // v10.3.1 FIX: Simplified update rule — the diff().affectedKeys() check
    // caused permission-denied when serverTimestamp() fields were included.
    // Now uses simple owner check + immutable field validation.
    // ═══════════════════════════════════════════════════════════════════════
    match /provider_listings/{listingId} {
      // Anyone authenticated can browse listings (search results)
      allow read: if isAuth();

      // Owner can create listings (identityIndex must be 0 or 1).
      // Admin can create listings for any user (used by demo experts tab —
      // admin builds fake provider profiles that need to appear in search).
      allow create: if (isAuth()
                        && request.resource.data.uid == request.auth.uid
                        && request.resource.data.identityIndex in [0, 1])
                    || isAdmin();

      // Owner can update their own listing (uid and identityIndex stay immutable).
      // Verified users can also update rating/reviewsCount (review aggregation).
      // Admin has full update access (for demo profile management).
      allow update: if (isAuth()
                        && resource.data.uid == request.auth.uid
                        && request.resource.data.uid == request.auth.uid
                        && request.resource.data.identityIndex == resource.data.identityIndex)
                    || (isAuth()
                        && onlyFields(['rating', 'reviewsCount']))
                    || isAdmin();

      // Owner or admin can delete
      allow delete: if (isAuth() && resource.data.uid == request.auth.uid)
                    || isAdmin();
    }


    // ═══════════════════════════════════════════════════════════════════════
    // COMMUNITY REQUESTS (Community Hub — v11.0.0)
    //
    // Anyone can create. Participants (requester or volunteer) can read/update.
    // Self-claim block enforced at service layer (requesterId != volunteerId).
    // ═══════════════════════════════════════════════════════════════════════
    match /community_requests/{reqId} {
      allow create: if isVerifiedAuth()
                    && request.resource.data.requesterId == request.auth.uid;

      allow read: if isAdmin()
                  || (isVerifiedAuth()
                      && (resource.data.requesterId  == request.auth.uid
                          || resource.data.volunteerId == request.auth.uid))
                  || (isVerifiedAuth() && resource.data.status == 'open');

      allow update: if isAdmin()
                    || (isVerifiedAuth()
                        && (resource.data.requesterId  == request.auth.uid
                            || resource.data.volunteerId == request.auth.uid
                            || resource.data.status == 'open'));

      allow delete: if false;
    }


    // ═══════════════════════════════════════════════════════════════════════
    // ANYTASKS 3.0 (global task marketplace)
    //
    // Creator posts tasks. Any verified user can browse open tasks and claim.
    // Self-assignment block (creatorId != auth.uid on claim) enforced at
    // service layer AND in the update rule below.
    // Escrow payment reuses the existing jobs collection pipeline.
    // ═══════════════════════════════════════════════════════════════════════
    match /anytasks/{taskId} {
      allow create: if isVerifiedAuth()
                    && request.resource.data.creatorId == request.auth.uid;

      // Open tasks: any auth user can browse. Non-open: only participants + admin.
      allow read: if isAdmin()
                  || (isVerifiedAuth() && resource.data.status == 'open')
                  || (isVerifiedAuth()
                      && (resource.data.creatorId  == request.auth.uid
                          || resource.data.providerId == request.auth.uid));

      // Creator can update (cancel, confirm, dispute).
      // Provider can update (claim open task, start work, submit proof) — but NOT own task.
      // Admin: full access.
      allow update: if isAdmin()
                    || (isVerifiedAuth() && resource.data.creatorId == request.auth.uid)
                    || (isVerifiedAuth()
                        && resource.data.creatorId != request.auth.uid
                        && (resource.data.providerId == request.auth.uid
                            || resource.data.status == 'open'));

      allow delete: if false;

      // Activity log subcollection (immutable audit trail)
      match /activity/{actId} {
        allow create: if isVerifiedAuth();
        allow read:   if isAdmin()
                      || (isVerifiedAuth()
                          && (get(/databases/$(database)/documents/anytasks/$(taskId)).data.creatorId == request.auth.uid
                              || get(/databases/$(database)/documents/anytasks/$(taskId)).data.providerId == request.auth.uid));
        allow update, delete: if false;
      }
    }

    // AnyTask categories — public read, admin write
    match /anytask_categories/{catId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin() || isCmsAdmin();
    }

    // AnyTask penalties — Cloud Function (Admin SDK) creates; user reads own
    match /anytask_penalties/{penId} {
      allow create: if false;
      allow read:   if isAdmin()
                    || (isVerifiedAuth() && resource.data.userId == request.auth.uid);
      allow update, delete: if false;
    }


    // ═══════════════════════════════════════════════════════════════════════
    // HELP REQUESTS (community volunteer help — from community_screen)
    // ═══════════════════════════════════════════════════════════════════════
    match /help_requests/{reqId} {
      allow create: if isVerifiedAuth()
                    && request.resource.data.userId == request.auth.uid;
      allow read:   if isVerifiedAuth();
      // Only the owner or admin can update (e.g., change status to closed).
      allow update: if isVerifiedAuth()
                    && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin() || isCmsAdmin();
    }


    // ═══════════════════════════════════════════════════════════════════════
    // VOLUNTEER TASKS (verified volunteer lifecycle)
    //
    // Anti-fraud: clientId != providerId enforced at the service layer.
    // Only the client (clientId) or provider (providerId) may read/update.
    // ═══════════════════════════════════════════════════════════════════════
    match /volunteer_tasks/{taskId} {
      allow create: if isVerifiedAuth()
                    && request.resource.data.providerId == request.auth.uid
                    && request.resource.data.clientId != request.auth.uid;

      allow read: if isAdmin()
                  || (isVerifiedAuth()
                      && (resource.data.clientId   == request.auth.uid
                          || resource.data.providerId == request.auth.uid));

      allow update: if isAdmin()
                    || (isVerifiedAuth()
                        && (resource.data.clientId   == request.auth.uid
                            || resource.data.providerId == request.auth.uid));

      allow delete: if false;
    }


    // ═══════════════════════════════════════════════════════════════════════
    // ADMIN COLLECTION (fee settings, broadcast config, etc.)
    // Any verified + authenticated user may READ (needed for fee calculations).
    // Only admins may WRITE.
    // ═══════════════════════════════════════════════════════════════════════
    match /admin/{docId} {
      allow read:  if isVerifiedAuth();
      allow write: if isAdmin() || isCmsAdmin();

      match /{nestedDoc=**} {
        allow read:  if isVerifiedAuth();
        allow write: if isAdmin() || isCmsAdmin();
      }
    }


    // ═══════════════════════════════════════════════════════════════════════
    // GAMIFICATION SETTINGS
    // ═══════════════════════════════════════════════════════════════════════
    match /settings_gamification/{docId} {
      allow read:  if isVerifiedAuth();
      allow write: if isAdmin() || isCmsAdmin();
    }


    // ═══════════════════════════════════════════════════════════════════════
    // SCHEDULED REMINDERS (rebook — written by Cloud Functions)
    // ═══════════════════════════════════════════════════════════════════════
    match /scheduled_reminders/{remId} {
      allow read:  if isAdmin()
                   || (isVerifiedAuth() && resource.data.userId == request.auth.uid);
      allow update: if isVerifiedAuth()
                    && resource.data.userId == request.auth.uid
                    && onlyFields(['isDismissed']);
      allow create, delete: if false; // Cloud Functions (Admin SDK) only
    }


    // ═══════════════════════════════════════════════════════════════════════
    // MAIL (Firebase Trigger Email extension)
    // ═══════════════════════════════════════════════════════════════════════
    match /mail/{docId} {
      allow create: if isVerifiedAuth();
      allow read, update, delete: if false;
    }


    // ═══════════════════════════════════════════════════════════════════════
    // ANALYTICS / LOGGING COLLECTIONS
    // ═══════════════════════════════════════════════════════════════════════

    match /search_logs/{id} {
      allow create: if isVerifiedAuth();
      allow read:   if isAdmin() || isCmsAdmin();
      allow update, delete: if false;
    }

    match /error_logs/{logId} {
      allow create: if isVerifiedAuth()
                    && request.resource.data.userId == request.auth.uid;
      allow read:   if isAdmin() || isCmsAdmin();
      allow update, delete: if false;
    }

    match /crash_reports_summary/{logId} {
      allow create: if isVerifiedAuth();
      allow read:   if isAdmin() || isCmsAdmin();
      allow update, delete: if false;
    }

    match /activity_log/{logId} {
      // Authenticated users log real-time events.
      // Unauthenticated sign-up flow logs reg_step_[1-5] with App Check only.
      allow create: if isVerifiedAuth()
                    || (isAppCheckValid()
                        && request.resource.data.type is string
                        && request.resource.data.type.matches('reg_step_[1-5]'));
      allow read:   if isAdmin() || isCmsAdmin();
      allow update, delete: if false;
    }

    match /admin_logs/{logId} {
      allow read:   if isAdmin() || isCmsAdmin();
      allow update: if isAdmin() && onlyFields(['isReviewed']);
      allow create, delete: if false; // Admin SDK only
    }

    match /admin_audit_log/{logId} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    // ── Demo bookings ──────────────────────────────────────────────────────
    // Records every customer attempt to book a demo provider profile.
    // Created by the customer's client when they tap "Book Now" on a demo
    // expert. Read by admins via the AdminDemoExpertsTab "bookings" sub-tab.
    //
    // Anyone authenticated can CREATE (the customer triggering the booking),
    // but the create is gated to records that name themselves as the
    // customerId. Reads + updates + deletes are admin-only.
    match /demo_bookings/{bookingId} {
      allow create: if isVerifiedAuth()
                    && request.resource.data.customerId == request.auth.uid;
      allow read:   if isAdmin();
      allow update: if isAdmin() && onlyFields(['status', 'contactedAt', 'adminNotes']);
      allow delete: if isAdmin();
    }

    // ── Pet services: dog walk live tracking ──────────────────────────────
    // Provider creates the doc on "Start Walk", appends to `path` array,
    // and finalizes on "End Walk". Customer + provider can read; only the
    // provider can write. Admin always read+write.
    match /dog_walks/{walkId} {
      allow read: if isAdmin()
                  || (isVerifiedAuth()
                      && (resource.data.customerId == request.auth.uid
                          || resource.data.providerId == request.auth.uid));
      allow create: if isVerifiedAuth()
                    && request.resource.data.providerId == request.auth.uid;
      allow update: if isAdmin()
                    || (isVerifiedAuth()
                        && resource.data.providerId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ── Pet services: daily boarding proof (photo + video per day) ────────
    // Top-level doc holds aggregate metadata; daily entries live in the
    // `days` sub-collection keyed by YYYYMMDD. Provider writes, customer
    // reads, admin both.
    match /boarding_proofs/{jobId} {
      allow read: if isAdmin()
                  || (isVerifiedAuth()
                      && (
                        // Inherit from the parent job — customer or provider
                        get(/databases/$(database)/documents/jobs/$(jobId)).data.customerId == request.auth.uid
                        || get(/databases/$(database)/documents/jobs/$(jobId)).data.expertId == request.auth.uid
                      ));
      allow write: if isAdmin();

      match /days/{dayKey} {
        allow read: if isAdmin()
                    || (isVerifiedAuth()
                        && (
                          get(/databases/$(database)/documents/jobs/$(jobId)).data.customerId == request.auth.uid
                          || get(/databases/$(database)/documents/jobs/$(jobId)).data.expertId == request.auth.uid
                        ));
        allow create, update: if isVerifiedAuth()
                              && get(/databases/$(database)/documents/jobs/$(jobId)).data.expertId == request.auth.uid;
        allow delete: if isAdmin();
      }
    }
    // ── Provider live GPS (Active Booking map) ──────────────────────────
    // Single doc per provider keyed by uid. Provider owns writes; any
    // authenticated user may read (the data is coarse live GPS — the
    // customer needs it to render a moving marker during an active job).
    // The provider is responsible for deleting the doc when the job ends
    // (see LiveLocationService.stopBroadcasting).
    match /provider_live_location/{providerUid} {
      allow read:   if isAdmin() || isVerifiedAuth();
      allow create, update: if isVerifiedAuth()
                    && request.auth.uid == providerUid
                    && request.resource.data.providerId == request.auth.uid;
      allow delete: if isAdmin()
                    || (isVerifiedAuth() && request.auth.uid == providerUid);
    }

    // ── AnyTasks (v14.0.0) — micro-task marketplace ────────────────────────
    // Root doc at any_tasks/{taskId}. Status flows: open → in_progress →
    // proof_submitted → completed (or disputed/cancelled). Payment release
    // happens server-side via the releaseTaskPayment CF, never from client.
    match /any_tasks/{taskId} {
      // Read: task participants (client, selected provider) + admin.
      // Open tasks are readable by any authenticated user (they are the
      // provider feed).
      allow read: if isAdmin()
                  || (isVerifiedAuth()
                      && (resource.data.status == 'open'
                          || resource.data.clientId == request.auth.uid
                          || resource.data.selectedProviderId == request.auth.uid));

      // Create: authenticated user creates their own task. Must match the
      // calling uid to clientId and status must start as 'open'.
      allow create: if isVerifiedAuth()
                    && request.resource.data.clientId == request.auth.uid
                    && request.resource.data.status == 'open'
                    && request.resource.data.budgetNis is number
                    && request.resource.data.budgetNis >= 10;

      // Update: participants only. Field allow-list prevents clients from
      // flipping status directly to 'completed' (must go via proof flow)
      // or mutating escrow fields (those are CF-only).
      allow update: if isAdmin()
                    || (isVerifiedAuth()
                        && resource.data.clientId == request.auth.uid
                        && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['title', 'description', 'status',
                                    'cancelledAt', 'proofText',
                                    'locationFrom', 'locationTo', 'imageUrl',
                                    'clientReviewDone']))
                    || (isVerifiedAuth()
                        && resource.data.selectedProviderId == request.auth.uid
                        && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['proofUrl', 'proofText', 'status',
                                    'proofSubmittedAt',
                                    'providerReviewDone']));

      // Delete: never from client. Admins only (e.g. fraud cleanup).
      allow delete: if isAdmin();

      // ── Responses subcollection (provider offers on a task) ─────────
      match /responses/{responseId} {
        allow read: if isAdmin()
                    || (isVerifiedAuth()
                        && (get(/databases/$(database)/documents/any_tasks/$(taskId)).data.clientId == request.auth.uid
                            || resource.data.providerId == request.auth.uid));
        allow create: if isVerifiedAuth()
                      && request.resource.data.providerId == request.auth.uid
                      && get(/databases/$(database)/documents/any_tasks/$(taskId)).data.status == 'open'
                      && get(/databases/$(database)/documents/any_tasks/$(taskId)).data.clientId != request.auth.uid;
        // Only the task's client can mark a response chosen/rejected (but
        // TaskEscrowService handles this via the tx that also moves money,
        // so in practice the client only updates via the Choose flow).
        allow update: if isAdmin()
                      || (isVerifiedAuth()
                          && get(/databases/$(database)/documents/any_tasks/$(taskId)).data.clientId == request.auth.uid);
        allow delete: if isAdmin();
      }

      // ── Milestones subcollection (step-by-step progress) ────────────
      match /milestones/{milestoneId} {
        allow read: if isAdmin()
                    || (isVerifiedAuth()
                        && (get(/databases/$(database)/documents/any_tasks/$(taskId)).data.clientId == request.auth.uid
                            || get(/databases/$(database)/documents/any_tasks/$(taskId)).data.selectedProviderId == request.auth.uid));
        // Created during task publish (batch write from client). The
        // parent task doc does NOT yet exist at rule-evaluation time inside
        // a batch, so a get() against the parent would fail and block the
        // whole batch. Keep this permissive (title string + valid order)
        // and rely on the task-level rule to gate real-world access.
        allow create: if isVerifiedAuth()
                      && request.resource.data.title is string
                      && request.resource.data.order is number;
        // Only the selected provider can mark complete.
        allow update: if isAdmin()
                      || (isVerifiedAuth()
                          && get(/databases/$(database)/documents/any_tasks/$(taskId)).data.selectedProviderId == request.auth.uid);
        allow delete: if isAdmin();
      }

      // ── Reviews subcollection (client rates provider) ───────────────
      match /reviews/{reviewId} {
        allow read: if isVerifiedAuth(); // Reviews are public (build trust)
        allow create: if isVerifiedAuth()
                      && request.resource.data.reviewerId == request.auth.uid
                      && get(/databases/$(database)/documents/any_tasks/$(taskId)).data.clientId == request.auth.uid
                      && get(/databases/$(database)/documents/any_tasks/$(taskId)).data.status == 'completed';
        allow update, delete: if isAdmin();
      }
    }

    // ── Admin credit grant idempotency cache (used by grantAdminCredit CF) ──
    // Cloud Function writes only — clients must never touch this.
    match /admin_credit_idempotency/{docId} {
      allow read, write: if false; // Admin SDK only via grantAdminCredit CF
    }

    // PR-C (v12.5.0): email verification codes — Cloud Function only.
    // Stores codeHash + salt (never plaintext). Client NEVER reads or writes —
    // all access via sendEmailVerificationCode / verifyEmailCode CFs.
    match /email_verification_codes/{uid} {
      allow read, write: if false;
    }

    match /reengagement_log/{logId} {
      allow create: if isAdmin() || isCmsAdmin();
      allow read:   if isAdmin() || isCmsAdmin();
      allow update, delete: if false;
    }

    match /broadcast_history/{docId} {
      allow create: if isAdmin() || isCmsAdmin();
      allow read:   if isAdmin() || isCmsAdmin();
      allow update, delete: if false;
    }


    // ═══════════════════════════════════════════════════════════════════════
    // ADMIN-ONLY COLLECTIONS (no client read or write)
    // ═══════════════════════════════════════════════════════════════════════

    match /categories_pending/{id} {
      allow read, write: if isAdmin() || isCmsAdmin();
    }

    match /market_alerts/{id} {
      allow read:  if isAdmin() || isCmsAdmin();
      allow write: if false;
    }

    match /market_opportunities/{docId} {
      allow read:  if isAdmin() || isCmsAdmin();
      allow write: if false;
    }


    // ═══════════════════════════════════════════════════════════════════════
    // INCOMPLETE REGISTRATIONS (abandoned-lead funnel — unauthenticated)
    // App Check required even without auth to prevent bot spam.
    // Field-size limits prevent storage-bloat injection.
    // ═══════════════════════════════════════════════════════════════════════
    match /incomplete_registrations/{sessionId} {
      allow create: if isAppCheckValid()
                    && request.resource.data.keys().size() <= 10
                    && request.resource.data.get('name',  '').size() <= 500
                    && request.resource.data.get('email', '').size() <= 200
                    && request.resource.data.get('phone', '').size() <= 30;

      allow update: if isAppCheckValid()
                    && request.resource.data.keys().size() <= 10;

      allow read:   if isAdmin() || isCmsAdmin();
      allow delete: if false;
    }


    // ═══════════════════════════════════════════════════════════════════════
    // MISSING-RULES AUDIT FIX (v8.9.4 — security hardening)
    // Collections found in code with NO prior rules — all locked down.
    // ═══════════════════════════════════════════════════════════════════════

    // ── Counter-offers (subcollection of job_requests) ─────────────────
    // Providers write counter-offers; only the job owner + admin can read.
    match /job_requests/{reqId}/counter_offers/{offerId} {
      allow create: if isVerifiedAuth()
                    && request.resource.data.providerId == request.auth.uid;
      allow read:   if isAdmin()
                    || (isVerifiedAuth()
                        && (get(/databases/$(database)/documents/job_requests/$(reqId)).data.clientId == request.auth.uid
                            || request.auth.uid == resource.data.providerId));
      allow update, delete: if isAdmin();
    }

    // ── Daily opportunities (Cloud Function generated) ────────────────
    match /daily_opportunities/{docId} {
      allow read:   if isVerifiedAuth();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    // ── System stats (billing KPIs — admin dashboard) ─────────────────
    // Written by Cloud Functions only. Admin read.
    match /system_stats/{docId} {
      allow read:  if isAdmin();
      allow write: if false; // Admin SDK (Cloud Functions) only
    }


    // ═══════════════════════════════════════════════════════════════════════
    // PENDINGBALANCE HARDENING
    // ═══════════════════════════════════════════════════════════════════════
    // NOTE: The users/{uid} rule at line ~140 allows ANY authenticated user
    // to write pendingBalance on ANY user doc via:
    //   || (isVerifiedAuth() && onlyFields(['pendingBalance']))
    //
    // This is documented as "acceptable because actual payouts read from
    // the jobs doc, not pendingBalance". However, it still allows:
    //   • User A inflating User B's pendingBalance to mislead the admin UI
    //   • Griefing by setting pendingBalance to a negative number
    //
    // RECOMMENDED FIX: restrict to increment-only via Cloud Function.
    // For now, the risk is ACCEPTED — see CLAUDE.md Section 11.
    // ═══════════════════════════════════════════════════════════════════════

  }
}
