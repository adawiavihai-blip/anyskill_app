rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isAuth()
          && (request.auth.token.email == 'adawiavihai@gmail.com'
              || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
    }

    // ── Users ─────────────────────────────────────────────────────
    match /users/{uid} {
      allow read:   if isAuth();
      allow create: if isOwner(uid) || (isAuth() && uid == 'anyskill_system') || isAdmin();
      allow update: if (isOwner(uid)
                        // 🔒 Server-side only (Cloud Functions / Admin SDK):
                        //    xp, current_xp, level, isPromoted  — gamification engine
                        //    isVerifiedProvider, isVerified      — compliance & identity
                        //    isAdmin                              — privilege escalation prevention
                        //    compliance                           — tax doc object (written during onboarding, cleared by admin)
                        //    balance                              — kept here; payment decrements use the branch below
                        && !request.resource.data.diff(resource.data)
                            .affectedKeys().hasAny([
                              'xp', 'current_xp', 'level', 'isPromoted',
                              'isVerifiedProvider', 'isVerified', 'isAdmin',
                              'balance',
                            ]))
                    // 💳 Owner may ONLY decrement their own balance (client-side escrow payment).
                    //    balance must already exist (is number) and new value ≤ old value.
                    //    Increments (payouts) are handled by Cloud Functions (Admin SDK).
                    || (isOwner(uid)
                        && request.resource.data.diff(resource.data)
                            .affectedKeys().hasOnly(['balance'])
                        && resource.data.balance is number
                        && request.resource.data.balance is number
                        && request.resource.data.balance <= resource.data.balance)
                    || isAdmin()
                    // כל משתמש מחובר יכול לעדכן רק rating + reviewsCount (לאחר ביקורת)
                    || (isAuth()
                        && request.resource.data.diff(resource.data)
                            .affectedKeys().hasOnly(['rating', 'reviewsCount']));
    }

    // ── Booking Slots (double-booking lock documents) ─────────────
    // One doc per expert+date+time slot. Created by the customer during booking
    // to prevent duplicate bookings. Released (deleted) by Cloud Function on
    // cancellation. Doc ID format: {expertId}_{YYYYMMDD}_{HHmm}
    match /bookingSlots/{slotId} {
      // Any authenticated user can read (pre-flight existence check in Phase 1)
      allow read:   if isAuth();
      // Customer creates the lock when booking; no customer field on the doc
      // so we simply require authentication (Phase 1 read already guards business logic).
      allow create: if isAuth();
      // Only admin or Cloud Functions may delete (cancellation cleanup)
      allow delete: if isAdmin();
      allow update: if false;
    }

    // ── Jobs (bookings) ───────────────────────────────────────────
    match /jobs/{jobId} {
      allow create: if isAuth()
                    && request.resource.data.customerId == request.auth.uid;
      allow read:   if isAdmin()
                    || (isAuth()
                        && (resource.data.customerId == request.auth.uid
                            || resource.data.expertId  == request.auth.uid));
      // Both parties may update their own job.
      // Provider (expertId) uses this to mark status → 'expert_completed'.
      // Customer (customerId) uses this to release escrow → 'completed'.
      // No field restriction here; business-logic guards live in PaymentModule.
      allow update: if isAdmin()
                    || (isAuth()
                        && resource.data.expertId   == request.auth.uid)
                    || (isAuth()
                        && resource.data.customerId == request.auth.uid);
    }

    // ── Transactions (wallet history) ─────────────────────────────
    // 🔒 Allow both userId (legacy) and senderId (withdrawal flow) patterns.
    match /transactions/{txId} {
      allow create: if isAuth()
                    && (request.resource.data.userId   == request.auth.uid
                        || request.resource.data.senderId == request.auth.uid);
      allow read:   if isAdmin()
                    || (isAuth()
                        && (resource.data.userId   == request.auth.uid
                            || resource.data.senderId == request.auth.uid
                            || resource.data.receiverId == request.auth.uid));
    }

    // ── Chats & messages ──────────────────────────────────────────
    // 🔒 Participant-only: only the two parties in users[] may read/write.
    // Previously: allow read,write: if isAuth()  ← any logged-in user could
    //             read any chat room by guessing the chatId.
    match /chats/{chatId} {
      allow create: if isAuth()
                    && request.auth.uid in request.resource.data.users;
      allow read, update, delete:
                    if isAuth()
                    && request.auth.uid in resource.data.users;

      match /messages/{msgId} {
        // Inherit parent-room access: check parent doc once per request.
        // Using get() here is justified — messages without a valid chat room
        // should never be accessible.
        allow read, write:
          if isAuth()
          && request.auth.uid in
             get(/databases/$(database)/documents/chats/$(chatId)).data.users;
      }

      match /unread_shards/{shardId} {
        // ניתן לקריאה בלבד ע"י משתמשים מחוברים — כתיבה מ-Cloud Function (Admin SDK) בלבד
        allow read: if isAuth()
                    && request.auth.uid in
                       get(/databases/$(database)/documents/chats/$(chatId)).data.users;
        allow write: if false;
      }
    }

    // ── Admin collection ──────────────────────────────────────────
    // Any authenticated user may READ (booking transaction needs feePercentage)
    // Only admin users may WRITE
    match /admin/{docId} {
      allow read:  if isAuth();
      allow write: if isAdmin();

      match /{nestedDoc=**} {
        allow read:  if isAuth();
        allow write: if isAdmin();
      }
    }

    // ── Platform earnings ─────────────────────────────────────────
    match /platform_earnings/{id} {
      allow create: if isAuth();
      allow read:   if isAdmin();
    }

    // ── Notifications (flat collection — written by Cloud Functions) ──────────
    match /notifications/{notifId} {
      // Owner may read their own notifications
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      // Owner may only flip isRead (no other field changes allowed from client)
      allow update: if isAuth()
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.diff(resource.data)
                        .affectedKeys().hasOnly(['isRead']);
      // create: Admin may write directly (emergency); normal path = Admin SDK in CF
      allow create: if isAdmin();
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── Notifications subcollection (legacy — written by client SDK) ──────────
    match /notifications/{uid}/userNotifications/{notifId} {
      allow read, write: if isOwner(uid);
    }

    // ── Categories (public read, admin write) ─────────────────────
    match /categories/{catId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── Reviews ───────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if (isAuth() && request.resource.data.reviewerId == request.auth.uid)
                    || isAdmin();
      // הספק יכול להוסיף תגובה (providerResponse) לביקורות שלו בלבד
      allow update: if isAuth()
                    && resource.data.expertId == request.auth.uid
                    && request.resource.data.diff(resource.data)
                        .affectedKeys().hasOnly(['providerResponse']);
    }

    // ── Banners (public read, admin write) ───────────────────────
    match /banners/{id} {
      allow read:  if true;
      allow write: if isAdmin();
      // כל משתמש מחובר יכול לספור לחיצה (clicks בלבד) — מעקב analytics
      allow update: if isAuth()
                    && request.resource.data.diff(resource.data)
                        .affectedKeys().hasOnly(['clicks']);
    }

    // ── Withdrawals ───────────────────────────────────────────────
    match /withdrawals/{id} {
      allow create: if isAuth()
                    && request.resource.data.userId == request.auth.uid;
      allow read:   if isAuth()
                    && resource.data.userId == request.auth.uid
                    || isAdmin();
      allow update: if isAdmin();
    }

    // ── Completed Works (Inspiration Feed — written by Cloud Function) ───
    match /completed_works/{docId} {
      allow read: if true;      // public — no sensitive data
      allow write: if false;    // Admin SDK only (Cloud Function)
    }

    // ── Rebook reminders (written by Cloud Functions only) ────────────
    match /scheduled_reminders/{remId} {
      allow read:  if isAdmin()
                   || (isAuth() && resource.data.userId == request.auth.uid);
      // Users may only flip isDismissed on their own reminders
      allow update: if isAuth()
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.diff(resource.data)
                        .affectedKeys().hasOnly(['isDismissed']);
      allow create, delete: if false; // Admin SDK (Cloud Functions) only
    }

    // ── Mail (Firebase Trigger Email extension) ───────────────────────
    // Any authenticated user may CREATE (onboarding notification, test button).
    // The Trigger Email extension (Admin SDK) reads/processes; clients cannot.
    match /mail/{docId} {
      allow create: if isAuth();
      allow read, update, delete: if false;
    }

    // ── Categories Pending (AI moderation queue) ──────────────────────
    // Written by the categorizeprovider Cloud Function and by approvecategory.
    // Only admins may read or write from the client SDK.
    match /categories_pending/{id} {
      allow read, write: if isAdmin();
    }

    // ── Search Logs (analytics — written by every searching user) ─────
    // Any authenticated user may CREATE a log entry (search_page.dart).
    // Only admins may READ (Business AI dashboard).
    // Immutable after creation — no update/delete from client.
    match /search_logs/{id} {
      allow create: if isAuth();
      allow read:   if isAdmin();
      allow update, delete: if false;
    }

    // ── Market Alerts (written by Cloud Function, read by admin) ──────
    match /market_alerts/{id} {
      allow read:  if isAdmin();
      allow write: if false; // Admin SDK (marketopportunitymonitor) only
    }

    // ── Skills Stories ────────────────────────────────────────────────
    // One document per provider (doc ID = uid).
    // Providers create/overwrite their own story.
    // Any authenticated user can read (discovery feed + viewer).
    // viewCount increments are allowed by any authenticated user.
    // hasActive / expiresAt are set by the client on upload and cleared
    // by the expireStories Cloud Function (Admin SDK).
    match /stories/{uid} {
      allow read:   if isAuth();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid)
                    // Any authenticated viewer can increment view/like counters
                    || (isAuth()
                        && request.resource.data.diff(resource.data)
                            .affectedKeys().hasOnly(['viewCount', 'likeCount', 'likedBy']));
      allow delete: if isOwner(uid) || isAdmin();
    }

    // ── Gamification Settings ────────────────────────────────────────
    // Admin writes XP event definitions and level thresholds.
    // Any authenticated user (and Cloud Functions) may read — event points
    // are needed client-side for display and inside updateUserXP function.
    match /settings_gamification/{docId} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    // ── Job Requests (quick order ecosystem) ──────────────────────────
    match /job_requests/{reqId} {
      // Any authenticated user can read open requests
      allow read: if isAuth();
      // Only the client themselves can create a request
      allow create: if isAuth()
                    && request.resource.data.clientId == request.auth.uid;
      // Providers update only the interest fields; client can close their own request
      allow update: if isAuth()
                    && (
                      // Provider expressing interest: only these fields change
                      request.resource.data.diff(resource.data)
                          .affectedKeys()
                          .hasOnly(['interestedProviders', 'interestedProviderNames',
                                    'interestedCount', 'status'])
                      // Client closing/editing their own request
                      || resource.data.clientId == request.auth.uid
                    );
      allow delete: if isAuth() && resource.data.clientId == request.auth.uid;
    }

    // ── Market Opportunities (zero-result search aggregation) ─────────────
    // Written exclusively by the marketopportunitymonitor Cloud Function (Admin SDK).
    // Admin reads for Business AI dashboard analysis.
    match /market_opportunities/{docId} {
      allow read:  if isAdmin();
      allow write: if false; // Admin SDK (marketopportunitymonitor) only
    }

    // ── Error logs (SystemPerformanceTab) ─────────────────────────────────
    // Any authenticated user can write their own error entries (client-side
    // FlutterError.onError handler).  Only admins can read the feed.
    match /error_logs/{logId} {
      allow create: if isAuth()
                    && request.resource.data.userId == request.auth.uid;
      allow read:   if isAdmin();
      allow update, delete: if false;
    }

    // ── Admin Logs (AI auto-category audit trail) ──────────────────────────
    // Written exclusively by Cloud Functions (Admin SDK — bypasses rules).
    // Only admins may read; "סמן כנבדק" update flips isReviewed only.
    match /admin_logs/{logId} {
      allow read:   if isAdmin();
      allow update: if isAdmin()
                    && request.resource.data.diff(resource.data)
                        .affectedKeys().hasOnly(['isReviewed']);
      allow create, delete: if false; // Admin SDK only
    }

    // ── Academy Courses (public catalogue) ───────────────────────────────────
    // Any visitor may read course metadata (title, description, videoUrl, quiz).
    // Only admins may create / edit / delete courses.
    match /courses/{courseId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── Academy User Progress ────────────────────────────────────────────────
    // Each user owns their progress subcollection: user_progress/{uid}/courses/
    // Admin may read all progress (analytics).
    match /user_progress/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      // Top-level doc is never written directly — only subcollection is.
      allow write: if false;

      match /courses/{courseId} {
        allow read:   if isOwner(uid) || isAdmin();
        // User writes their own watch-progress; completeCourse() uses a batch
        // that also updates users/{uid} xp — both allowed by respective rules.
        allow create, update: if isOwner(uid);
        allow delete: if false;
      }
    }

    // ── Activity Log (admin Live Feed) ───────────────────────────────────────
    // Written by:
    //   • Cloud Functions (logJobRequestCreated, logJobAccepted, etc.) via Admin SDK
    //   • Flutter client (ChatGuardService.logBypassAttempt, _checkDemoExpert)
    // Only admins may read.
    match /activity_log/{logId} {
      // Authenticated users AND unauthenticated sign-up flow (reg_step_1..5)
      allow create: if isAuth()
                    || (request.resource.data.type is string
                        && request.resource.data.type.matches('reg_step_[1-5]'));
      allow read:   if isAdmin();
      allow update, delete: if false;
    }

    // ── Incomplete Registrations (abandoned-lead funnel) ──────────────────────
    // Written by unauthenticated users during sign-up (partial saves).
    // Admin may read/update for re-engagement; users may update their own session.
    match /incomplete_registrations/{sessionId} {
      allow create: if true;  // unauthenticated during sign-up
      allow update: if true;  // progress updates + completion mark
      allow read:   if isAdmin();
      allow delete: if false;
    }

    // ── Re-engagement Log ─────────────────────────────────────────────────────
    match /reengagement_log/{logId} {
      allow create: if isAdmin();
      allow read:   if isAdmin();
      allow update, delete: if false;
    }

    // ── Broadcast History ────────────────────────────────────────────────────
    // Written by Flutter client (admin panel) AND sendGlobalBroadcast CF.
    // Only admins may read.
    match /broadcast_history/{docId} {
      allow create: if isAuth();
      allow read:   if isAdmin();
      allow update, delete: if false;
    }

    // ── System Settings (global UI config) ───────────────────────────────────
    // Holds categoryCardScale, logoSize, brandColor, etc. — no PII.
    // Public read: login/register screens load before auth, so unauthenticated
    // users need to read logo-size values for real-time branding control.
    // Only admin writes.
    match /system_settings/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── App Hints (contextual help icons — admin-controlled content) ─────────
    // Public read: any user (including unauthenticated) may read help content.
    // Only admin may write (create / update / delete hints).
    match /app_hints/{screenKey} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── Volunteer Requests ───────────────────────────────────────────────────
    // Any authenticated user may create a volunteer request.
    // Cloud Function logVolunteerRequest (Admin SDK) reads on creation.
    // Admin may read and update (moderation).
    match /volunteer_requests/{reqId} {
      allow create: if isAuth()
                    && request.resource.data.clientId == request.auth.uid;
      allow read:   if isAuth()
                    && resource.data.clientId == request.auth.uid
                    || isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }
  }
}
