rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════════════
    // CORE HELPER FUNCTIONS
    // ═══════════════════════════════════════════════════════════════════════

    // True when a Firebase Auth session exists.
    function isAuth() {
      return request.auth != null;
    }

    // ── App Check ──────────────────────────────────────────────────────────
    // App Check enforcement is handled EXCLUSIVELY by the Firebase Console
    // toggle (Firebase Console → App Check → Firestore → Enforced / Monitor).
    //
    // When set to "Enforced": Firebase rejects every request without a valid
    //   App Check token BEFORE the rules are evaluated.  No rule change needed.
    // When set to "Monitor": requests are logged but allowed through, so the
    //   rules run normally for all authenticated users.
    //
    // We do NOT check request.app inside rules because:
    //   • It breaks Monitor mode (request.app is null even for legitimate users).
    //   • It breaks localhost dev (reCAPTCHA can't run on 127.0.0.1).
    //   • It is redundant when Enforce mode is active (Firebase already blocked
    //     the unauthenticated request before rules execute).
    //
    // isAppCheckValid() is kept ONLY for public-catalogue rules where we want
    // an extra check that the request comes from the app binary (not a browser
    // curl) even before the user has signed in.
    function isAppCheckValid() {
      return request.app != null;
    }

    // Authenticated user — the primary gate for all client operations.
    // App Check enforcement is the Firebase Console's responsibility, not ours.
    function isVerifiedAuth() {
      return isAuth();
    }

    // The current user owns this document (matches the UID path parameter).
    function isOwner(uid) {
      return isVerifiedAuth() && request.auth.uid == uid;
    }

    // Admin check — Firestore flag only; email removed (see security audit).
    // isAdmin can only be set via Admin SDK / Firebase Console.
    function isAdmin() {
      return isVerifiedAuth()
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // CMS admin check — now uses the same Firestore isAdmin flag.
    // Previously was email-based; unified to prevent hardcoded credentials.
    // Kept as a separate function for readability in collection rules.
    function isCmsAdmin() {
      return isAdmin();
    }

    // ── Field-level write guards (reusable) ───────────────────────────────

    // Returns true when the update touches ONLY the listed keys.
    function onlyFields(keys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys);
    }

    // Returns true when the update does NOT touch any of the listed keys.
    function doesNotTouch(keys) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(keys);
    }


    // ═══════════════════════════════════════════════════════════════════════
    // USERS
    // ═══════════════════════════════════════════════════════════════════════
    //
    // Privacy model:
    //   • Any authenticated + app-verified user may READ a profile.
    //     All public fields (name, bio, skills, rating, profileImage) live
    //     at the top level and are intentionally visible for search results.
    //   • Sensitive fields (balance, bankDetails, taxId, phone) are protected
    //     at the WRITE layer — only the owner can write them, and the read
    //     exposure is an accepted trade-off of a flat document model.
    //     For a future hardening step, move sensitive fields to a private
    //     subcollection: users/{uid}/private/data (owner-read only).
    //   • Server-only fields (xp, isAdmin, isVerified, balance increments)
    //     are blocked at the write layer below.
    //
    match /users/{uid} {
      // Owner can always read their own doc (even during signup before it exists).
      // Any other authenticated user can read public profile data.
      allow read: if request.auth != null;

      // Owner can create their own profile. System account also allowed.
      // Uses direct auth check — no get() calls that could fail on missing docs.
      allow create: if request.auth != null && request.auth.uid == uid;

      allow update: if
        // ── Owner general update ───────────────────────────────────────────
        // Owner may update any field EXCEPT server-only fields.
        (isOwner(uid) && doesNotTouch([
          'xp', 'current_xp', 'level', 'isPromoted',
          'isVerifiedProvider', 'isVerified', 'isAdmin',
          'balance',
        ]))
        // ── Owner balance decrement (client-side escrow payment) ──────────
        // Owner may ONLY decrease their own balance. Increments are
        // handled exclusively by Cloud Functions via Admin SDK.
        || (isOwner(uid)
            && onlyFields(['balance'])
            && resource.data.balance is number
            && request.resource.data.balance is number
            && request.resource.data.balance <= resource.data.balance)
        // ── Admin full access ──────────────────────────────────────────────
        || isAdmin()
        // ── Review aggregation ────────────────────────────────────────────
        // Any verified user may update only the rating + reviewsCount fields
        // (written after a client review submission). Business logic in the
        // client prevents abuse; a Cloud Function audit runs nightly.
        || (isVerifiedAuth() && onlyFields(['rating', 'reviewsCount']))
        // Any verified user may update only the customerRating +
        // customerReviewsCount fields (written after an expert review
        // of a customer is published).
        || (isVerifiedAuth() && onlyFields(['customerRating', 'customerReviewsCount']))
        // ── Volunteer badge update ───────────────────────────────────────
        // Client confirms volunteer task completion → updates provider's
        // badge timestamp and count. XP increment is handled by CF.
        || (isVerifiedAuth() && onlyFields(['lastVolunteerTaskAt', 'volunteerTaskCount', 'hasActiveVolunteerBadge']))
        // ── Engagement: streak + profile boost ───────────────────────────
        // Provider writes streak data on own doc; engagement service writes
        // profileBoostUntil when a boost card is awarded.
        || (isOwner(uid) && onlyFields(['streak', 'lastStreakDate', 'streakBestEver', 'lastDailyDropDate', 'profileBoostUntil']))
        // ── Escrow credit (pendingBalance) ───────────────────────────────
        // Only the owner may write pendingBalance on their OWN doc (via CF),
        // OR any auth user may increment it (client credits expert during
        // escrow payment). The actual payout reads netAmountForExpert from
        // the jobs doc — not pendingBalance — so manipulation has no
        // financial effect on real payouts.
        || (isVerifiedAuth() && onlyFields(['pendingBalance']));

      // Deletion is only performed by the Account Deletion Cloud Function
      // (Admin SDK) or the self-service delete flow (account_deletion_service.dart
      // calls currentUser.delete(), and the CF cleans up the doc).
      allow delete: if isOwner(uid) || isAdmin();
    }


    // ═══════════════════════════════════════════════════════════════════════
    // PRIVATE USER SUBCOLLECTIONS
    // Strictly owner-only. No other authenticated user — not even an admin
    // using the client SDK — may access these paths.
    // (Admin SDK via Cloud Functions bypasses all rules and is unaffected.)
    // ═══════════════════════════════════════════════════════════════════════

    // ── Academy User Progress ─────────────────────────────────────────────
    match /user_progress/{uid} {
      allow read:  if isOwner(uid) || isAdmin();
      allow write: if false; // top-level doc never written directly

      match /courses/{courseId} {
        allow read:           if isOwner(uid) || isAdmin();
        allow create, update: if isOwner(uid);
        allow delete:         if false;
      }
    }

    // ── Private financial data ──────────────────────────────────────────
    // Sensitive fields (balance, bankDetails, taxId, phone) that should
    // NOT be readable by other users. Owner + Admin only.
    // Cloud Functions (Admin SDK) bypass rules and can always read/write.
    match /users/{uid}/private/{docId} {
      allow read:           if isOwner(uid) || isAdmin();
      allow create, update: if isOwner(uid) || isAdmin();
      allow delete:         if isAdmin();
    }

    // ── Legacy per-user notification subcollection ────────────────────────
    match /notifications/{uid}/userNotifications/{notifId} {
      allow read, write: if isOwner(uid);
    }


    // ═══════════════════════════════════════════════════════════════════════
    // NOTIFICATIONS (flat collection — written by Cloud Functions)
    // ═══════════════════════════════════════════════════════════════════════
    match /notifications/{notifId} {
      // Owner reads their own notifications.
      allow read: if isVerifiedAuth() && resource.data.userId == request.auth.uid;

      // Owner may only flip isRead — no other field changes from the client.
      allow update: if isVerifiedAuth()
                    && resource.data.userId == request.auth.uid
                    && onlyFields(['isRead']);

      // Normal creation path = Admin SDK in Cloud Functions.
      // Client code also creates notifications for volunteer/help_request flows.
      // Size limit: prevent abuse at scale (max 10 fields, body < 1000 chars).
      allow create: if isAdmin()
                    || (isVerifiedAuth()
                        && request.resource.data.keys().size() <= 10
                        && request.resource.data.get('body', '').size() <= 1000);

      // Owner may dismiss (delete) their own notifications.
      allow delete: if isVerifiedAuth() && resource.data.userId == request.auth.uid;
    }


    // ═══════════════════════════════════════════════════════════════════════
    // JOBS (bookings)
    // Only the customer and expert involved in a booking may access it.
    // ═══════════════════════════════════════════════════════════════════════
    match /jobs/{jobId} {
      // Customer creates the job and must be the customerId author.
      allow create: if isVerifiedAuth()
                    && request.resource.data.customerId == request.auth.uid;

      // Only the two parties (or admin) may read.
      allow read: if isAdmin()
                  || (isVerifiedAuth()
                      && (resource.data.customerId == request.auth.uid
                          || resource.data.expertId  == request.auth.uid));

      // Both parties may update (status transitions, completion).
      allow update: if isAdmin()
                    || (isVerifiedAuth()
                        && (resource.data.expertId   == request.auth.uid
                            || resource.data.customerId == request.auth.uid));

      allow delete: if false; // historical record — never deleted by client
    }


    // ═══════════════════════════════════════════════════════════════════════
    // TRANSACTIONS (wallet history)
    // Only the sender, receiver, or admin may access a transaction.
    // ═══════════════════════════════════════════════════════════════════════
    match /transactions/{txId} {
      // Sender creates their own transaction record.
      allow create: if isVerifiedAuth()
                    && (request.resource.data.userId   == request.auth.uid
                        || request.resource.data.senderId == request.auth.uid);

      // Only the two parties (or admin) may read.
      allow read: if isAdmin()
                  || (isVerifiedAuth()
                      && (resource.data.userId     == request.auth.uid
                          || resource.data.senderId  == request.auth.uid
                          || resource.data.receiverId == request.auth.uid));

      allow update, delete: if false; // immutable financial records
    }


    // ═══════════════════════════════════════════════════════════════════════
    // CHATS & MESSAGES
    // Strictly participant-only: only the two users listed in chat.users[]
    // may read or write. Guessing a chatId grants nothing.
    // ═══════════════════════════════════════════════════════════════════════
    match /chats/{chatId} {
      allow create: if isVerifiedAuth()
                    && request.auth.uid in request.resource.data.users;

      allow read, update:
            if isVerifiedAuth()
            && request.auth.uid in resource.data.users;

      // Allow participant to delete the chat room document.
      allow delete: if isVerifiedAuth()
                    && request.auth.uid in resource.data.users;

      match /messages/{msgId} {
        // Inherit parent-room access: caller must be in the parent chat's users[].
        allow read, write:
          if isVerifiedAuth()
          && request.auth.uid in
             get(/databases/$(database)/documents/chats/$(chatId)).data.users;
      }

      match /unread_shards/{shardId} {
        // Read-only for participants — shards are written by Cloud Functions only.
        allow read: if isVerifiedAuth()
                    && request.auth.uid in
                       get(/databases/$(database)/documents/chats/$(chatId)).data.users;
        allow write: if false;
      }
    }


    // ═══════════════════════════════════════════════════════════════════════
    // QUOTES (price quotes sent via chat)
    // Only the provider and client involved may read or update.
    // ═══════════════════════════════════════════════════════════════════════
    match /quotes/{quoteId} {
      allow create: if isVerifiedAuth()
                    && request.resource.data.providerId == request.auth.uid;

      allow read: if isAdmin()
                  || (isVerifiedAuth()
                      && (resource.data.providerId == request.auth.uid
                          || resource.data.clientId  == request.auth.uid));

      allow update: if isAdmin()
                    || (isVerifiedAuth()
                        && (resource.data.providerId == request.auth.uid
                            || resource.data.clientId  == request.auth.uid));

      allow delete: if isAdmin() || isCmsAdmin();
    }


    // ═══════════════════════════════════════════════════════════════════════
    // WITHDRAWALS
    // ═══════════════════════════════════════════════════════════════════════
    match /withdrawals/{id} {
      allow create: if isVerifiedAuth()
                    && request.resource.data.userId == request.auth.uid;

      // Explicit parentheses to avoid && vs || precedence ambiguity.
      allow read: if isAdmin()
                  || (isVerifiedAuth() && resource.data.userId == request.auth.uid);

      allow update: if isAdmin() || isCmsAdmin();
      allow delete: if false;
    }


    // ═══════════════════════════════════════════════════════════════════════
    // BOOKING SLOTS (double-booking lock documents)
    // ═══════════════════════════════════════════════════════════════════════
    match /bookingSlots/{slotId} {
      allow read:   if isVerifiedAuth();
      allow create: if isVerifiedAuth();
      allow delete: if isAdmin() || isCmsAdmin();
      allow update: if false;
    }


    // ═══════════════════════════════════════════════════════════════════════
    // PLATFORM EARNINGS (commission records)
    // ═══════════════════════════════════════════════════════════════════════
    match /platform_earnings/{id} {
      allow create: if isVerifiedAuth();
      allow read:   if isAdmin() || isCmsAdmin();
      allow update, delete: if false;
    }


    // ═══════════════════════════════════════════════════════════════════════
    // PUBLIC CATALOGUES
    // Read by anyone from the verified app (isAppCheckValid()).
    // Unauthenticated visitors may browse before signing in.
    // All writes are admin-only.
    // ═══════════════════════════════════════════════════════════════════════

    match /categories/{catId} {
      // Authenticated users always get through; unauthenticated visitors on
      // production need a valid App Check token (reCAPTCHA / Play Integrity).
      allow read:  if isAuth() || isAppCheckValid();
      allow write: if isAdmin() || isCmsAdmin();
    }

    match /application_content/{locale} {
      // CMS content overrides: readable by authenticated users, writable only by CMS admin.
      allow read:  if isAuth() || isAppCheckValid();
      allow write: if isAdmin() || isCmsAdmin();

      // Nested documents (if any) inherit the same rules.
      match /{document=**} {
        allow read:  if isAuth() || isAppCheckValid();
        allow write: if isAdmin() || isCmsAdmin();
      }
    }

    match /courses/{courseId} {
      allow read:  if isAuth() || isAppCheckValid();
      allow write: if isAdmin() || isCmsAdmin();
    }

    match /system_settings/{docId} {
      allow read:  if isAuth() || isAppCheckValid();
      allow write: if isAdmin() || isCmsAdmin();
    }

    match /app_hints/{screenKey} {
      allow read:  if isAuth() || isAppCheckValid();
      allow write: if isAdmin() || isCmsAdmin();
    }

    match /banners/{id} {
      allow read:   if isAuth() || isAppCheckValid();
      allow create, delete: if isAdmin() || isCmsAdmin();
      allow update: if isAdmin()
                    || (isVerifiedAuth() && onlyFields(['clicks']));
    }

    match /completed_works/{docId} {
      allow read:  if isAuth() || isAppCheckValid(); // public inspiration feed
      allow write: if false;                         // Admin SDK (Cloud Function) only
    }


    // ═══════════════════════════════════════════════════════════════════════
    // REVIEWS  (double-blind: published when both submit OR after 7 days)
    //
    // isPublished starts false; flipped to true by client code when:
    //   • both job.clientReviewDone AND job.providerReviewDone are true, OR
    //   • 7 days have passed since the review was created (lazy publish).
    //
    // Neither condition leaks the other party's content — only the flag
    // is toggled client-side; content fields are immutable after creation.
    // ═══════════════════════════════════════════════════════════════════════

    // Checks that the current user is a job participant AND both sides
    // have now submitted their review — used to allow immediate publish.
    function canPublishReview(jobId) {
      let job = get(/databases/$(database)/documents/jobs/$(jobId)).data;
      return (job.expertId    == request.auth.uid
              || job.customerId == request.auth.uid)
          && job.clientReviewDone   == true
          && job.providerReviewDone == true;
    }

    match /reviews/{reviewId} {
      allow read: if isAuth() || isAppCheckValid();

      // A verified user may create a review when:
      //   1. They are the reviewer (reviewerId == their uid), AND
      //   2. They are actually a participant in the referenced job
      //      (prevents writing reviews for jobs they were not part of).
      allow create: if isAdmin()
                    || (isVerifiedAuth()
                        && request.resource.data.reviewerId == request.auth.uid
                        && (get(/databases/$(database)/documents/jobs/$(request.resource.data.jobId)).data.customerId == request.auth.uid
                            || get(/databases/$(database)/documents/jobs/$(request.resource.data.jobId)).data.expertId  == request.auth.uid));

      allow update: if isAdmin()
                    // The reviewee (expert) may add/edit their reply to a
                    // client review written about them.
                    || (isVerifiedAuth()
                        && resource.data.revieweeId   == request.auth.uid
                        && resource.data.isClientReview == true
                        && onlyFields(['providerResponse']))
                    // Immediate publish: a job participant may flip isPublished
                    // once BOTH sides have submitted their review.
                    || (isVerifiedAuth()
                        && onlyFields(['isPublished'])
                        && request.resource.data.isPublished == true
                        && canPublishReview(resource.data.jobId))
                    // Lazy publish: any authenticated user may flip isPublished
                    // after the 7-day double-blind window has expired.
                    || (isVerifiedAuth()
                        && onlyFields(['isPublished'])
                        && request.resource.data.isPublished == true
                        && request.time > resource.data.createdAt + duration.value(7, 'd'));

      allow delete: if isAdmin() || isCmsAdmin();
    }


    // ═══════════════════════════════════════════════════════════════════════
    // SKILLS STORIES
    // ═══════════════════════════════════════════════════════════════════════
    match /stories/{uid} {
      allow read:   if isVerifiedAuth();
      allow create: if isOwner(uid);
      // Owner can update any field. Other users can only toggle
      // engagement fields (view/like) — prevents story content hijacking.
      allow update: if isOwner(uid)
                    || isAdmin()
                    || (isVerifiedAuth()
                        && onlyFields(['viewCount', 'likeCount', 'likedBy']));
      allow delete: if isOwner(uid) || isAdmin();
    }


    // ═══════════════════════════════════════════════════════════════════════
    // JOB REQUESTS (quick-order board)
    // ═══════════════════════════════════════════════════════════════════════
    match /job_requests/{reqId} {
      allow read:   if isVerifiedAuth();
      allow create: if isVerifiedAuth()
                    && request.resource.data.clientId == request.auth.uid;
      allow update: if isVerifiedAuth()
                    && (onlyFields(['interestedProviders', 'interestedProviderNames',
                                    'interestedCount', 'status'])
                        || resource.data.clientId == request.auth.uid);
      allow delete: if isVerifiedAuth() && resource.data.clientId == request.auth.uid;
    }


    // ═══════════════════════════════════════════════════════════════════════
    // VOLUNTEER REQUESTS
    // ═══════════════════════════════════════════════════════════════════════
    match /volunteer_requests/{reqId} {
      allow create: if isVerifiedAuth()
                    && request.resource.data.clientId == request.auth.uid;
      allow read:   if isAdmin()
                    || (isVerifiedAuth() && resource.data.clientId == request.auth.uid);
      allow update: if isAdmin() || isCmsAdmin();
      allow delete: if false;
    }


    // ═══════════════════════════════════════════════════════════════════════
    // CATEGORY REQUESTS ("Other" custom category pending admin approval)
    // ═══════════════════════════════════════════════════════════════════════
    match /category_requests/{reqId} {
      allow create: if isVerifiedAuth()
                    && request.resource.data.userId == request.auth.uid;
      allow read:   if isAdmin()
                    || (isVerifiedAuth() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || isCmsAdmin();
      allow delete: if isAdmin() || isCmsAdmin();
    }


    // ═══════════════════════════════════════════════════════════════════════
    // SUPPORT TICKETS (user↔admin support chat)
    //
    // Users create tickets and read/update their own.
    // Admins can read and update all tickets.
    // ═══════════════════════════════════════════════════════════════════════
    match /support_tickets/{ticketId} {
      allow create: if isVerifiedAuth()
                    && request.resource.data.userId == request.auth.uid;

      allow read: if isAdmin()
                  || (isVerifiedAuth() && resource.data.userId == request.auth.uid);

      allow update: if isAdmin()
                    || (isVerifiedAuth() && resource.data.userId == request.auth.uid);

      allow delete: if isAdmin() || isCmsAdmin();

      match /messages/{msgId} {
        allow read: if isAdmin()
                    || (isVerifiedAuth()
                        && get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.userId == request.auth.uid);

        allow create: if isAdmin()
                      || (isVerifiedAuth()
                          && get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.userId == request.auth.uid);
      }
    }


    // ═══════════════════════════════════════════════════════════════════════
    // APP SETTINGS (admin-managed global configuration)
    // Readable by all authenticated users (e.g., sound mappings on startup).
    // Writable only by admins.
    // ═══════════════════════════════════════════════════════════════════════
    match /app_settings/{docId} {
      allow read:  if isVerifiedAuth();
      allow write: if isAdmin() || isCmsAdmin();
    }


    // ═══════════════════════════════════════════════════════════════════════
    // USER REWARDS (Daily Drop, streak milestones, engagement rewards)
    // ═══════════════════════════════════════════════════════════════════════
    match /user_rewards/{rewardId} {
      allow create: if isVerifiedAuth()
                    && request.resource.data.userId == request.auth.uid;
      allow read:   if isVerifiedAuth()
                    && resource.data.userId == request.auth.uid;
      allow update: if isVerifiedAuth()
                    && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() || isCmsAdmin();
    }


    // ═══════════════════════════════════════════════════════════════════════
    // JOB BROADCASTS (urgent first-come-first-served claims)
    //
    // Created by the client (via JobBroadcastService). Any authenticated
    // provider may read (to see available broadcasts) and update (to claim).
    // Claim atomicity is enforced by Firestore transaction in the service.
    // ═══════════════════════════════════════════════════════════════════════
    match /job_broadcasts/{broadcastId} {
      allow create: if isVerifiedAuth()
                    && request.resource.data.clientId == request.auth.uid;

      allow read: if isVerifiedAuth();

      // Only the broadcast owner or an admin can update.
      // Claim atomicity is enforced by Firestore transaction in the service —
      // providers update status to 'claimed' + set claimedBy fields.
      allow update: if isVerifiedAuth()
                    && (resource.data.clientId == request.auth.uid
                        || onlyFields(['status', 'claimedBy', 'claimedByName', 'claimedAt']));

      allow delete: if isAdmin() || isCmsAdmin();
    }


    // ═══════════════════════════════════════════════════════════════════════
    // HELP REQUESTS (community volunteer help — from community_screen)
    // ═══════════════════════════════════════════════════════════════════════
    match /help_requests/{reqId} {
      allow create: if isVerifiedAuth()
                    && request.resource.data.userId == request.auth.uid;
      allow read:   if isVerifiedAuth();
      // Only the owner or admin can update (e.g., change status to closed).
      allow update: if isVerifiedAuth()
                    && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin() || isCmsAdmin();
    }


    // ═══════════════════════════════════════════════════════════════════════
    // VOLUNTEER TASKS (verified volunteer lifecycle)
    //
    // Anti-fraud: clientId != providerId enforced at the service layer.
    // Only the client (clientId) or provider (providerId) may read/update.
    // ═══════════════════════════════════════════════════════════════════════
    match /volunteer_tasks/{taskId} {
      allow create: if isVerifiedAuth()
                    && request.resource.data.providerId == request.auth.uid
                    && request.resource.data.clientId != request.auth.uid;

      allow read: if isAdmin()
                  || (isVerifiedAuth()
                      && (resource.data.clientId   == request.auth.uid
                          || resource.data.providerId == request.auth.uid));

      allow update: if isAdmin()
                    || (isVerifiedAuth()
                        && (resource.data.clientId   == request.auth.uid
                            || resource.data.providerId == request.auth.uid));

      allow delete: if false;
    }


    // ═══════════════════════════════════════════════════════════════════════
    // ADMIN COLLECTION (fee settings, broadcast config, etc.)
    // Any verified + authenticated user may READ (needed for fee calculations).
    // Only admins may WRITE.
    // ═══════════════════════════════════════════════════════════════════════
    match /admin/{docId} {
      allow read:  if isVerifiedAuth();
      allow write: if isAdmin() || isCmsAdmin();

      match /{nestedDoc=**} {
        allow read:  if isVerifiedAuth();
        allow write: if isAdmin() || isCmsAdmin();
      }
    }


    // ═══════════════════════════════════════════════════════════════════════
    // GAMIFICATION SETTINGS
    // ═══════════════════════════════════════════════════════════════════════
    match /settings_gamification/{docId} {
      allow read:  if isVerifiedAuth();
      allow write: if isAdmin() || isCmsAdmin();
    }


    // ═══════════════════════════════════════════════════════════════════════
    // SCHEDULED REMINDERS (rebook — written by Cloud Functions)
    // ═══════════════════════════════════════════════════════════════════════
    match /scheduled_reminders/{remId} {
      allow read:  if isAdmin()
                   || (isVerifiedAuth() && resource.data.userId == request.auth.uid);
      allow update: if isVerifiedAuth()
                    && resource.data.userId == request.auth.uid
                    && onlyFields(['isDismissed']);
      allow create, delete: if false; // Cloud Functions (Admin SDK) only
    }


    // ═══════════════════════════════════════════════════════════════════════
    // MAIL (Firebase Trigger Email extension)
    // ═══════════════════════════════════════════════════════════════════════
    match /mail/{docId} {
      allow create: if isVerifiedAuth();
      allow read, update, delete: if false;
    }


    // ═══════════════════════════════════════════════════════════════════════
    // ANALYTICS / LOGGING COLLECTIONS
    // ═══════════════════════════════════════════════════════════════════════

    match /search_logs/{id} {
      allow create: if isVerifiedAuth();
      allow read:   if isAdmin() || isCmsAdmin();
      allow update, delete: if false;
    }

    match /error_logs/{logId} {
      allow create: if isVerifiedAuth()
                    && request.resource.data.userId == request.auth.uid;
      allow read:   if isAdmin() || isCmsAdmin();
      allow update, delete: if false;
    }

    match /crash_reports_summary/{logId} {
      allow create: if isVerifiedAuth();
      allow read:   if isAdmin() || isCmsAdmin();
      allow update, delete: if false;
    }

    match /activity_log/{logId} {
      // Authenticated users log real-time events.
      // Unauthenticated sign-up flow logs reg_step_[1-5] with App Check only.
      allow create: if isVerifiedAuth()
                    || (isAppCheckValid()
                        && request.resource.data.type is string
                        && request.resource.data.type.matches('reg_step_[1-5]'));
      allow read:   if isAdmin() || isCmsAdmin();
      allow update, delete: if false;
    }

    match /admin_logs/{logId} {
      allow read:   if isAdmin() || isCmsAdmin();
      allow update: if isAdmin() && onlyFields(['isReviewed']);
      allow create, delete: if false; // Admin SDK only
    }

    match /admin_audit_log/{logId} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    match /reengagement_log/{logId} {
      allow create: if isAdmin() || isCmsAdmin();
      allow read:   if isAdmin() || isCmsAdmin();
      allow update, delete: if false;
    }

    match /broadcast_history/{docId} {
      allow create: if isAdmin() || isCmsAdmin();
      allow read:   if isAdmin() || isCmsAdmin();
      allow update, delete: if false;
    }


    // ═══════════════════════════════════════════════════════════════════════
    // ADMIN-ONLY COLLECTIONS (no client read or write)
    // ═══════════════════════════════════════════════════════════════════════

    match /categories_pending/{id} {
      allow read, write: if isAdmin() || isCmsAdmin();
    }

    match /market_alerts/{id} {
      allow read:  if isAdmin() || isCmsAdmin();
      allow write: if false;
    }

    match /market_opportunities/{docId} {
      allow read:  if isAdmin() || isCmsAdmin();
      allow write: if false;
    }


    // ═══════════════════════════════════════════════════════════════════════
    // INCOMPLETE REGISTRATIONS (abandoned-lead funnel — unauthenticated)
    // App Check required even without auth to prevent bot spam.
    // Field-size limits prevent storage-bloat injection.
    // ═══════════════════════════════════════════════════════════════════════
    match /incomplete_registrations/{sessionId} {
      allow create: if isAppCheckValid()
                    && request.resource.data.keys().size() <= 10
                    && request.resource.data.get('name',  '').size() <= 500
                    && request.resource.data.get('email', '').size() <= 200
                    && request.resource.data.get('phone', '').size() <= 30;

      allow update: if isAppCheckValid()
                    && request.resource.data.keys().size() <= 10;

      allow read:   if isAdmin() || isCmsAdmin();
      allow delete: if false;
    }


    // ═══════════════════════════════════════════════════════════════════════
    // MISSING-RULES AUDIT FIX (v8.9.4 — security hardening)
    // Collections found in code with NO prior rules — all locked down.
    // ═══════════════════════════════════════════════════════════════════════

    // ── Counter-offers (subcollection of job_requests) ─────────────────
    // Providers write counter-offers; only the job owner + admin can read.
    match /job_requests/{reqId}/counter_offers/{offerId} {
      allow create: if isVerifiedAuth()
                    && request.resource.data.providerId == request.auth.uid;
      allow read:   if isAdmin()
                    || (isVerifiedAuth()
                        && (get(/databases/$(database)/documents/job_requests/$(reqId)).data.clientId == request.auth.uid
                            || request.auth.uid == resource.data.providerId));
      allow update, delete: if isAdmin();
    }

    // ── Daily opportunities (Cloud Function generated) ────────────────
    match /daily_opportunities/{docId} {
      allow read:   if isVerifiedAuth();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    // ── System stats (billing KPIs — admin dashboard) ─────────────────
    // Written by Cloud Functions only. Admin read.
    match /system_stats/{docId} {
      allow read:  if isAdmin();
      allow write: if false; // Admin SDK (Cloud Functions) only
    }


    // ═══════════════════════════════════════════════════════════════════════
    // PENDINGBALANCE HARDENING
    // ═══════════════════════════════════════════════════════════════════════
    // NOTE: The users/{uid} rule at line ~140 allows ANY authenticated user
    // to write pendingBalance on ANY user doc via:
    //   || (isVerifiedAuth() && onlyFields(['pendingBalance']))
    //
    // This is documented as "acceptable because actual payouts read from
    // the jobs doc, not pendingBalance". However, it still allows:
    //   • User A inflating User B's pendingBalance to mislead the admin UI
    //   • Griefing by setting pendingBalance to a negative number
    //
    // RECOMMENDED FIX: restrict to increment-only via Cloud Function.
    // For now, the risk is ACCEPTED — see CLAUDE.md Section 11.
    // ═══════════════════════════════════════════════════════════════════════

  }
}
