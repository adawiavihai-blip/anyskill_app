rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Profile images ─────────────────────────────────────────────────────
    // Public read (appears in search); only the owner may upload.
    match /profile_images/{userId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Chat files (images & voice notes) ──────────────────────────────────
    // Only participants whose UID appears in the chatId segment may read/write.
    match /chats/{chatId}/{allPaths=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid in chatId.split('_');
    }

    // ── Story videos ───────────────────────────────────────────────────────
    // Path: stories/{userId}_{timestamp}.{ext}
    // Any authenticated user may read (video player in StoriesRow).
    // A provider may write only a file whose name starts with their own UID,
    // preventing one user from overwriting another's story.
    match /stories/{storyFile} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && storyFile.matches(request.auth.uid + '_.*');
    }

    // ── Gallery / portfolio images ─────────────────────────────────────────
    match /gallery/{userId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── ID / Passport verification images ─────────────────────────────────
    // Sensitive: owner may upload their own, only admin (or owner) may read.
    match /id_verifications/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
      allow read:  if request.auth != null
                   && (request.auth.uid == userId
                       || request.auth.token.email == 'adawiavihai@gmail.com');
    }

    // ── Fallback: other authenticated uploads ─────────────────────────────
    // Covers category_images, banners, business_docs, compliance_docs,
    // tax_certificates, and any future paths.
    match /{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
