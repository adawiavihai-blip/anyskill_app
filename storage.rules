rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Helpers ────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isAdmin() {
      // Admin flag lives in Firestore — single source of truth.
      return isSignedIn() && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    function isImageContentType() {
      return request.resource.contentType.matches('image/.*');
    }
    function isMediaContentType() {
      return request.resource.contentType.matches('image/.*')
          || request.resource.contentType.matches('video/.*');
    }
    function underSize(maxMb) {
      return request.resource.size < maxMb * 1024 * 1024;
    }

    // ── Profile images ─────────────────────────────────────────────────────
    // Public read (appears in search); only the owner may upload.
    match /profile_images/{userId}/{allPaths=**} {
      allow read:  if isSignedIn();
      allow write: if isOwner(userId) && isImageContentType() && underSize(5);
    }

    // ── Chat files (images & voice notes) ──────────────────────────────────
    // Only participants whose UID appears in the chatId segment may read/write.
    match /chats/{chatId}/{allPaths=**} {
      allow read, write: if isSignedIn()
                         && request.auth.uid in chatId.split('_');
    }

    // ── Story videos ───────────────────────────────────────────────────────
    // Path: stories/{userId}_{timestamp}.{ext}
    // Any authenticated user may read (video player in StoriesRow).
    // A provider may write only a file whose name starts with their own UID,
    // preventing one user from overwriting another's story.
    match /stories/{storyFile} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn()
                   && storyFile.matches(request.auth.uid + '_.*')
                   && isMediaContentType()
                   && underSize(50);
    }

    // ── Gallery / portfolio images ─────────────────────────────────────────
    match /gallery/{userId}/{allPaths=**} {
      allow read:  if isSignedIn();
      allow write: if isOwner(userId) && isImageContentType() && underSize(10);
    }

    // ── Intro videos (provider registration — 60s max) ────────────────────
    // Path: intro_videos/{uid}/v_{timestamp}.{ext}
    match /intro_videos/{userId}/{allPaths=**} {
      allow read:  if isSignedIn();
      allow write: if isOwner(userId) && isMediaContentType() && underSize(50);
    }

    // ── ID / Passport verification images ─────────────────────────────────
    // Sensitive: owner may upload their own; only admin or owner may read.
    match /id_verifications/{userId}/{allPaths=**} {
      allow write: if isOwner(userId) && isImageContentType() && underSize(10);
      allow read:  if isOwner(userId) || isAdmin();
    }

    // ── Live selfie verification (Law 8) ──────────────────────────────────
    // Path: verification_selfies/{uid}.jpg
    // Owner uploads from front camera; admin reads side-by-side with ID doc.
    match /verification_selfies/{selfieFile} {
      allow write: if isSignedIn()
                   && selfieFile.matches(request.auth.uid + '\\..*')
                   && isImageContentType()
                   && underSize(5);
      allow read:  if isSignedIn()
                   && (selfieFile.matches(request.auth.uid + '\\..*') || isAdmin());
    }

    // ── Provider verification video ───────────────────────────────────────
    // Path: users/{uid}/verification_video.mp4
    match /users/{userId}/{allPaths=**} {
      allow read:  if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) && isMediaContentType() && underSize(100);
    }

    // ── Business documents (license, tax certificate) ─────────────────────
    // Path: business_docs/{uid}/license_*.{ext}
    //
    // SECURITY (pen-test 2026-05-15 — VULN-008): the previous rule had no
    // content-type guard, so a provider could upload `.exe` / `.html` /
    // `.svg` (with embedded JS) here. Admins downloading these from the
    // verification console would execute the payload. The new guard
    // accepts image/* AND application/pdf (legitimate business docs are
    // commonly PDF scans).
    match /business_docs/{userId}/{allPaths=**} {
      allow read:  if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId)
                   && underSize(10)
                   && (
                        request.resource.contentType.matches('image/.*')
                        || request.resource.contentType == 'application/pdf'
                      );
    }

    // ── ID documents (identity verification — v3 provider registration) ───
    // Path: id_docs/{uid}/id_*.{ext}
    // Owner writes (JPG/PNG only), owner + admin read.
    match /id_docs/{userId}/{allPaths=**} {
      allow read:  if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) && isImageContentType() && underSize(10);
    }

    // ── Job photos (customer uploads attached to a booking) ───────────────
    // Path: job_photos/{uid}/{timestamp}.{ext}
    match /job_photos/{userId}/{allPaths=**} {
      allow read:  if isSignedIn();
      allow write: if isOwner(userId) && isImageContentType() && underSize(10);
    }

    // ── Booking requirement images (uploaded at checkout) ────────────────
    // Path: booking_requirements/{customerUid}/{requirementId}_{ts}.{ext}
    // Used by Home-Services schemas (pest control, plumbing, etc.) to
    // collect a "visual diagnosis" photo from the customer before payment.
    // Customer uploads under their own UID; provider/admin can read.
    match /booking_requirements/{userId}/{allPaths=**} {
      allow read:  if isSignedIn();
      allow write: if isOwner(userId) && isImageContentType() && underSize(10);
    }

    // ── Dog-walk route map snapshots (provider posts on End Walk) ────────
    // Path: dog_walks/{walkId}/route_map.png
    //
    // SECURITY (v15.x audit Round C, 2026-04-25): the parent dog_walks
    // doc carries `providerId` and `customerId` (mirroring the job's
    // expertId/customerId). Storage write is now restricted to the
    // walk's actual provider — without this, any signed-in user could
    // overwrite the route map with a fake/garbage image.
    match /dog_walks/{walkId}/{allPaths=**} {
      allow read:  if isSignedIn()
                   && firestore.exists(/databases/(default)/documents/dog_walks/$(walkId))
                   && (
                        firestore.get(/databases/(default)/documents/dog_walks/$(walkId)).data.providerId == request.auth.uid
                        || firestore.get(/databases/(default)/documents/dog_walks/$(walkId)).data.customerId == request.auth.uid
                      );
      allow write: if isSignedIn()
                   && isImageContentType()
                   && underSize(5)
                   && firestore.exists(/databases/(default)/documents/dog_walks/$(walkId))
                   && firestore.get(/databases/(default)/documents/dog_walks/$(walkId)).data.providerId == request.auth.uid;
    }

    // ── Motorcycle bike-types catalog images (admin uploads) ─────────────
    // Path: motorcycle_bike_types/{typeId}.{ext}
    // Read by any signed-in user (provider + customer both render the
    // catalog).
    //
    // SECURITY (pen-test 2026-05-15 — VULN-007): the previous rule allowed
    // ANY signed-in user to write to this path. A long comment justified
    // this as "low-blast-radius" because the Firestore catalog doc is
    // admin-only, but that reasoning was wrong: an attacker could
    // (a) overwrite existing catalog images with a CDN-cached XSS-SVG
    // payload visible to every provider + customer; (b) host arbitrary
    // content on the platform CDN (offensive imagery, phishing mockups,
    // potentially CSAM — legal liability). The write rule is now
    // properly admin-gated using the same firestore.get pattern that
    // gates other admin-write Storage paths.
    match /motorcycle_bike_types/{file=**} {
      allow read:  if isSignedIn();
      allow write: if isAdmin() && isImageContentType() && underSize(5);
    }

    // ── Motorcycle towing before/after photos (per active tow) ───────────
    // Path: motorcycle_tows/{towId}/{phase}_{ts}.{ext}  (phase=before|after)
    // Same security pattern as dog_walks: parent motorcycle_tows doc
    // carries providerId + customerId, and only the actual tow's
    // provider can write images.
    match /motorcycle_tows/{towId}/{allPaths=**} {
      allow read:  if isSignedIn()
                   && firestore.exists(/databases/(default)/documents/motorcycle_tows/$(towId))
                   && (
                        firestore.get(/databases/(default)/documents/motorcycle_tows/$(towId)).data.providerId == request.auth.uid
                        || firestore.get(/databases/(default)/documents/motorcycle_tows/$(towId)).data.customerId == request.auth.uid
                      );
      allow write: if isSignedIn()
                   && isImageContentType()
                   && underSize(10)
                   && firestore.exists(/databases/(default)/documents/motorcycle_tows/$(towId))
                   && firestore.get(/databases/(default)/documents/motorcycle_tows/$(towId)).data.providerId == request.auth.uid;
    }

    // ── Motorcycle towing booking-time photos (customer pre-tow) ─────────
    // Path: motorcycle_tow_pre_photos/{userId}/{ts}.{ext}
    // Customer uploads images of the bike from the booking block BEFORE
    // the job exists (no parent doc to gate against). Owner-write,
    // signed-in read so the provider can preview at booking time.
    match /motorcycle_tow_pre_photos/{userId}/{allPaths=**} {
      allow read:  if isSignedIn();
      allow write: if isOwner(userId) && isImageContentType() && underSize(10);
    }

    // ── Flash Auction photos (CLAUDE.md §57) ─────────────────────────────
    // Path: flash_auction_photos/{customerUid}/{ts}.{ext}
    // Customer uploads images of the bike on the location screen BEFORE
    // the auction doc is created. Same pattern as motorcycle_tow_pre_photos
    // — owner-write, signed-in read so the eventually-matched provider
    // can preview before submitting an offer.
    match /flash_auction_photos/{userId}/{allPaths=**} {
      allow read:  if isSignedIn();
      allow write: if isOwner(userId) && isImageContentType() && underSize(10);
    }

    // ── Delivery Express pre-broadcast photos (CLAUDE.md §78) ─────────────
    // Path: delivery_express_photos/{customerUid}/{ts}.{ext}
    // Customer uploads optional images of the package on the location
    // screen BEFORE the auction doc is created. Same pattern as
    // flash_auction_photos — owner-write, signed-in read so the
    // eventually-matched courier can preview before accepting.
    match /delivery_express_photos/{userId}/{allPaths=**} {
      allow read:  if isSignedIn();
      allow write: if isOwner(userId) && isImageContentType() && underSize(10);
    }

    // ── Boarding daily proofs (provider uploads photo + video per day) ───
    // Path: boarding_proofs/{jobId}/{date}_{kind}.{ext}  (kind = photo|video)
    //
    // SECURITY (v15.x audit, 2026-04-25): inherits participant identity
    // from the parent job doc (matches the pattern documented in
    // CLAUDE.md §3d). Without this gate, any signed-in user could write
    // arbitrary 50 MB media files to ANY jobId, including jobs they are
    // not a participant in — enabling tampering with another booking's
    // proof feed (fraudulent care evidence) and free arbitrary content
    // hosting on the platform's CDN.
    //
    // Read: customer or provider on the job (or admin via Firestore SDK).
    // Write: ONLY the provider on the job, image/video content type only.
    match /boarding_proofs/{jobId}/{allPaths=**} {
      allow read:  if isSignedIn()
                   && firestore.exists(/databases/(default)/documents/jobs/$(jobId))
                   && (
                        firestore.get(/databases/(default)/documents/jobs/$(jobId)).data.expertId == request.auth.uid
                        || firestore.get(/databases/(default)/documents/jobs/$(jobId)).data.customerId == request.auth.uid
                      );
      allow write: if isSignedIn()
                   && isMediaContentType()
                   && underSize(50)
                   && firestore.exists(/databases/(default)/documents/jobs/$(jobId))
                   && firestore.get(/databases/(default)/documents/jobs/$(jobId)).data.expertId == request.auth.uid;
    }

    // ── Community evidence (photo proof for volunteer task) ──────────────
    // SECURITY (pen-test 2026-05-15 — VULN-009): the old flat path
    // `community_evidence/{docId}_{ts}.{ext}` had no participant gate
    // (any signed-in user could read+write every evidence file by
    // brute-forcing the docId). The new nested path
    // `community_evidence/{docId}/{file}` matches the same docId as the
    // parent `community_requests/{docId}` doc, so the rule can use a
    // Firestore lookup to gate by participant + admin.
    //
    // Migration: the Dart upload site (community_hub_screen.dart +
    // complete_volunteering_screen.dart) now writes to the nested path.
    // Reads of files uploaded under the legacy flat path are NOT supported
    // by the new rule — they fall under the storage default-deny. If
    // legacy files must be served, run a one-shot admin migration script
    // to move them into the new structure before deploying these rules.
    match /community_evidence/{docId}/{file=**} {
      allow read:  if isAdmin()
                   || (isSignedIn()
                       && firestore.exists(/databases/(default)/documents/community_requests/$(docId))
                       && (
                            firestore.get(/databases/(default)/documents/community_requests/$(docId)).data.requesterId == request.auth.uid
                            || firestore.get(/databases/(default)/documents/community_requests/$(docId)).data.volunteerId == request.auth.uid
                          ));
      allow write: if isSignedIn()
                   && isImageContentType()
                   && underSize(10)
                   && firestore.exists(/databases/(default)/documents/community_requests/$(docId))
                   && firestore.get(/databases/(default)/documents/community_requests/$(docId)).data.volunteerId == request.auth.uid;
    }

    // ── AnyTask proofs (provider's "work done" evidence) ─────────────────
    // Path: anytask_proofs/{taskId}/proof_*.{ext}
    //
    // SECURITY (v15.x audit Round B, 2026-04-25 — Vuln 8):
    // Proof of work gates the customer's `releaseTaskPayment` decision —
    // if anyone could overwrite the proof, an attacker could replace the
    // provider's real photos with fake "all done" images and trick the
    // customer into releasing escrow. Now strictly: only the selected
    // provider on the parent any_tasks doc may write.
    match /anytask_proofs/{taskId}/{allPaths=**} {
      allow read:  if isSignedIn()
                   && firestore.exists(/databases/(default)/documents/any_tasks/$(taskId))
                   && (
                        firestore.get(/databases/(default)/documents/any_tasks/$(taskId)).data.clientId == request.auth.uid
                        || firestore.get(/databases/(default)/documents/any_tasks/$(taskId)).data.selectedProviderId == request.auth.uid
                      );
      allow write: if isSignedIn()
                   && isMediaContentType()
                   && underSize(20)
                   && firestore.exists(/databases/(default)/documents/any_tasks/$(taskId))
                   && firestore.get(/databases/(default)/documents/any_tasks/$(taskId)).data.selectedProviderId == request.auth.uid;
    }

    // ── AnyTasks v14.0.0 — client task attachments + provider proof ──────
    // Path: any_tasks/{taskId}/{file}  (task_image_*, proof_*, etc.)
    //
    // SECURITY (v15.x audit Round B, 2026-04-25 — Vuln 9):
    // Both client (task images at publish/edit) AND selected provider
    // (proof) may write here. Anyone-signed-in writes were vulnerable to
    // tampering — an attacker could overwrite the client's task image
    // with deceptive content or replace the provider's proof. Now gated
    // to participants only.
    match /any_tasks/{taskId}/{allPaths=**} {
      allow read:  if isSignedIn()
                   && firestore.exists(/databases/(default)/documents/any_tasks/$(taskId))
                   && (
                        // 'open' tasks are part of the public provider feed
                        firestore.get(/databases/(default)/documents/any_tasks/$(taskId)).data.status == 'open'
                        || firestore.get(/databases/(default)/documents/any_tasks/$(taskId)).data.clientId == request.auth.uid
                        || firestore.get(/databases/(default)/documents/any_tasks/$(taskId)).data.selectedProviderId == request.auth.uid
                      );
      allow write: if isSignedIn()
                   && isImageContentType()
                   && underSize(10)
                   && firestore.exists(/databases/(default)/documents/any_tasks/$(taskId))
                   && (
                        firestore.get(/databases/(default)/documents/any_tasks/$(taskId)).data.clientId == request.auth.uid
                        || firestore.get(/databases/(default)/documents/any_tasks/$(taskId)).data.selectedProviderId == request.auth.uid
                      );
    }

    // ── Banners (admin-managed home screen carousel) ─────────────────────
    match /banners/{bannerFile} {
      allow read:  if isSignedIn();
      allow write: if isAdmin() && isImageContentType() && underSize(5);
    }

    // ── Category images (admin-managed catalog) ──────────────────────────
    match /category_images/{categoryFile} {
      allow read:  if isSignedIn();
      allow write: if isAdmin() && isImageContentType() && underSize(5);
    }
    match /categories/{docId}/{allPaths=**} {
      allow read:  if isSignedIn();
      allow write: if isAdmin() && isImageContentType() && underSize(5);
    }

    // ── Demo expert avatars (admin-managed) ──────────────────────────────
    match /demo_experts/{allPaths=**} {
      allow read:  if isSignedIn();
      allow write: if isAdmin() && isImageContentType() && underSize(5);
    }

    // ── Dog profile photos (Pet Stay Tracker v13.0.0) ─────────────────────
    // Owner uploads their pet's photo. Any signed-in user can read (the
    // provider sees the photo via the job-side snapshot; the Storage rule
    // itself just needs to allow a signed-in GET on the canonical URL).
    match /dog_profiles/{ownerId}/{allPaths=**} {
      allow read:  if isSignedIn();
      allow write: if isOwner(ownerId) && isImageContentType() && underSize(5);
    }

    // ── Sound Studio uploads (§53) ─────────────────────────────────────────
    // Path: sounds/uploaded/{filename}
    // Admin-only upload + content-type / size enforcement. Read open to all
    // signed-in users so AudioService can stream the URL on app init.
    match /sounds/uploaded/{soundFile} {
      allow read:  if isSignedIn();
      allow write: if isAdmin()
                   && request.resource.contentType.matches('audio/.*')
                   && underSize(5);
    }

    // ── DEFAULT DENY ──────────────────────────────────────────────────────
    // Any path not explicitly matched above is rejected.
    // To add a new feature that needs storage, add a `match` block above this
    // line — never relax the default deny.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
