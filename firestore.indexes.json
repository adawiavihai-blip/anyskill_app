{
  "indexes": [
    {
      "collectionGroup": "users",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "isProvider",  "order": "ASCENDING" },
        { "fieldPath": "serviceType", "order": "ASCENDING" }
      ]
    },
    {
      "collectionGroup": "jobs",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "expertId",  "order": "ASCENDING"  },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    {
      "collectionGroup": "jobs",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "expertId", "order": "ASCENDING" },
        { "fieldPath": "status",   "order": "ASCENDING" }
      ]
    },
    {
      "collectionGroup": "jobs",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "customerId", "order": "ASCENDING"  },
        { "fieldPath": "createdAt",  "order": "DESCENDING" }
      ]
    },
    {
      "collectionGroup": "jobs",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "customerId", "order": "ASCENDING" },
        { "fieldPath": "status",     "order": "ASCENDING" }
      ]
    },
    {
      "collectionGroup": "jobs",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "status",    "order": "ASCENDING"  },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    {
      "collectionGroup": "job_requests",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "status",    "order": "ASCENDING"  },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    {
      "collectionGroup": "job_requests",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "status",    "order": "ASCENDING"  },
        { "fieldPath": "category",  "order": "ASCENDING"  },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    {
      "collectionGroup": "job_requests",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "clientId",  "order": "ASCENDING"  },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    {
      "collectionGroup": "scheduled_reminders",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "status", "order": "ASCENDING" },
        { "fieldPath": "sendAt", "order": "ASCENDING" }
      ]
    },
    {
      "collectionGroup": "transactions",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "userId",    "order": "ASCENDING"  },
        { "fieldPath": "timestamp", "order": "DESCENDING" }
      ]
    },
    {
      "collectionGroup": "withdrawals",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "status",      "order": "ASCENDING"  },
        { "fieldPath": "requestedAt", "order": "DESCENDING" }
      ]
    },
    {
      "collectionGroup": "notifications",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "userId",    "order": "ASCENDING"  },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    {
      "collectionGroup": "notifications",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "userId", "order": "ASCENDING" },
        { "fieldPath": "isRead", "order": "ASCENDING" }
      ]
    },
    {
      "collectionGroup": "reviews",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "expertId",  "order": "ASCENDING"  },
        { "fieldPath": "timestamp", "order": "DESCENDING" }
      ]
    },
    {
      "collectionGroup": "messages",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "receiverId", "order": "ASCENDING" },
        { "fieldPath": "isRead",     "order": "ASCENDING" }
      ]
    },
    {
      "collectionGroup": "messages",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "senderId",  "order": "ASCENDING"  },
        { "fieldPath": "timestamp", "order": "DESCENDING" }
      ]
    },
    {
      "collectionGroup": "users",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "isPromoted",          "order": "ASCENDING" },
        { "fieldPath": "promotionExpiryDate", "order": "ASCENDING" }
      ]
    },
    {
      "collectionGroup": "users",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "isProvider",    "order": "ASCENDING" },
        { "fieldPath": "lastBookingAt", "order": "ASCENDING" }
      ]
    },
    {
      "collectionGroup": "search_logs",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "query",       "order": "ASCENDING"  },
        { "fieldPath": "zeroResults", "order": "ASCENDING"  },
        { "fieldPath": "timestamp",   "order": "DESCENDING" }
      ]
    },

    // ── Added for Re-Engagement Engine (home_tab.dart _remindersStream) ───
    {
      "collectionGroup": "scheduled_reminders",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "userId",      "order": "ASCENDING" },
        { "fieldPath": "isDismissed", "order": "ASCENDING" },
        { "fieldPath": "isActive",    "order": "ASCENDING" }
      ]
    },

    // ── Added for Expert Application workflow (admin_screen.dart) ─────────
    {
      "collectionGroup": "users",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "isPendingExpert", "order": "ASCENDING" },
        { "fieldPath": "createdAt",       "order": "DESCENDING" }
      ]
    },

    // ── Expert task list: 3-field composite for provider task queries ──────
    {
      "collectionGroup": "jobs",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "expertId",  "order": "ASCENDING"  },
        { "fieldPath": "status",    "order": "ASCENDING"  },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },

    // ── Admin live feed: filter by type, sorted by time ───────────────────
    {
      "collectionGroup": "activity_log",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "type",      "order": "ASCENDING"  },
        { "fieldPath": "timestamp", "order": "DESCENDING" }
      ]
    },

    // ── Notifications: userId + isRead + createdAt (bell icon stream) ─────
    {
      "collectionGroup": "notifications",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "userId",    "order": "ASCENDING"  },
        { "fieldPath": "isRead",    "order": "ASCENDING"  },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },

    // ── Jobs: customerId + status + createdAt (client bookings with sort) ─
    {
      "collectionGroup": "jobs",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "customerId", "order": "ASCENDING"  },
        { "fieldPath": "status",     "order": "ASCENDING"  },
        { "fieldPath": "createdAt",  "order": "DESCENDING" }
      ]
    },

    // ── Reengagement: completed jobs by date (Cloud Function daily scan) ──
    {
      "collectionGroup": "jobs",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "status",    "order": "ASCENDING"  },
        { "fieldPath": "createdAt", "order": "ASCENDING"  }
      ]
    },

    // ═══════════════════════════════════════════════════════════════════════
    // SCALE-UP INDEXES (added 2026-03-30 for 3M+ users)
    // ═══════════════════════════════════════════════════════════════════════

    // ── volunteer_tasks: anti-fraud cooldown check ──────────────────────────
    {
      "collectionGroup": "volunteer_tasks",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "providerId",   "order": "ASCENDING"  },
        { "fieldPath": "clientId",     "order": "ASCENDING"  },
        { "fieldPath": "status",       "order": "ASCENDING"  },
        { "fieldPath": "completedAt",  "order": "DESCENDING" }
      ]
    },
    // ── volunteer_tasks: reciprocal block check ─────────────────────────────
    {
      "collectionGroup": "volunteer_tasks",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "providerId", "order": "ASCENDING" },
        { "fieldPath": "clientId",   "order": "ASCENDING" },
        { "fieldPath": "status",     "order": "ASCENDING" }
      ]
    },
    // ── volunteer_tasks: daily XP cap + recent completed count ───────────────
    {
      "collectionGroup": "volunteer_tasks",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "providerId",  "order": "ASCENDING"  },
        { "fieldPath": "status",      "order": "ASCENDING"  },
        { "fieldPath": "completedAt", "order": "DESCENDING" }
      ]
    },
    // ── volunteer_tasks: client pending stream ──────────────────────────────
    {
      "collectionGroup": "volunteer_tasks",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "clientId",  "order": "ASCENDING"  },
        { "fieldPath": "status",    "order": "ASCENDING"  },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    // ── job_broadcasts: open by category sorted by time ─────────────────────
    {
      "collectionGroup": "job_broadcasts",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "status",    "order": "ASCENDING"  },
        { "fieldPath": "category",  "order": "ASCENDING"  },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    // ── support_tickets: admin inbox by status + date ────────────────────────
    {
      "collectionGroup": "support_tickets",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "status",    "order": "ASCENDING"  },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    // ── support_tickets: user's own tickets ──────────────────────────────────
    {
      "collectionGroup": "support_tickets",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "userId",    "order": "ASCENDING"  },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    // ── user_rewards: active rewards for a user ─────────────────────────────
    {
      "collectionGroup": "user_rewards",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "userId",    "order": "ASCENDING" },
        { "fieldPath": "status",    "order": "ASCENDING" },
        { "fieldPath": "expiresAt", "order": "ASCENDING" }
      ]
    }
  ],
  "fieldOverrides": []
}
