    // ═══════════════════════════════════════════════════════════════════════
    // SECURITY/PERFORMANCE FIXES (added 2026-04-10 — pre-launch audit)
    // ═══════════════════════════════════════════════════════════════════════

    // ── users: online provider lookup (search_repository.watchOnline) ─────
    // Without this index, the query .where('isProvider', ==, true)
    //   .where('isOnline', ==, true) silently returns empty on web.
    {
      "collectionGroup": "users",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "isProvider", "order": "ASCENDING" },
        { "fieldPath": "isOnline",   "order": "ASCENDING" }
      ]
    },

    // ── job_requests: open requests with no responders (admin insights) ───
    // admin_insights_tab.dart: status==open + interestedCount==0
    {
      "collectionGroup": "job_requests",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "status",          "order": "ASCENDING" },
        { "fieldPath": "interestedCount", "order": "ASCENDING" }
      ]
    },

    // ── jobs: urgent completed analytics (admin insights) ─────────────────
    // admin_insights_tab.dart: status==completed + isUrgent==true
    // Cuts read amplification from 500 docs to ~50.
    {
      "collectionGroup": "jobs",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "status",   "order": "ASCENDING" },
        { "fieldPath": "isUrgent", "order": "ASCENDING" }
      ]
    }
  ],
  "fieldOverrides": []
}
