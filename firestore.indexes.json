{
  "indexes": [
    {
      "_comment": "Flash Auction §57 — provider opportunities strip query: FlashAuctionService.watchActiveAuctionsForProvider does `.where('notifiedProviderIds', arrayContains: uid).orderBy('createdAt', desc)`. Without this composite index, Firestore silently returns 0 docs on web — provider gets FCM but the strip stays empty (real bug from live test on 2026-05-11).",
      "collectionGroup": "flash_auctions",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "notifiedProviderIds", "arrayConfig": "CONTAINS" },
        { "fieldPath": "createdAt",           "order": "DESCENDING" }
      ]
    },
    {
      "_comment": "Babysitter Emergency §76 — sister-collection to flash_auctions. BabysitterEmergencyService.watchActiveEmergenciesForProvider runs the identical `arrayContains + orderBy(createdAt DESC)` pattern. Without this composite index, the provider's babysitter-emergency strip on opportunities stays empty even when the dispatch CF added their uid to notifiedProviderIds (re-bug of the same shape as §57 — 2026-05-12).",
      "collectionGroup": "babysitter_emergencies",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "notifiedProviderIds", "arrayConfig": "CONTAINS" },
        { "fieldPath": "createdAt",           "order": "DESCENDING" }
      ]
    },
    {
      "_comment": "Banners Studio §51 — VIP active-subscription watcher (vip_upgrade_button._watchActiveSub). Without this the IN-clause query silently errors and the button stays stuck on 'Not VIP' even after a successful purchase.",
      "collectionGroup": "vip_subscriptions",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "providerId", "order": "ASCENDING" },
        { "fieldPath": "status",     "order": "ASCENDING" }
      ]
    },
